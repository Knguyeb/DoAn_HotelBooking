@{
    ViewData["Title"] = "Liên hệ";
}

<link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<div class="container mt-5 text-light">
    <h1 class="text-center mb-4">Liên hệ với chúng tôi</h1>
    <p class="text-center lead">
        Nếu bạn có thắc mắc hoặc cần hỗ trợ, vui lòng điền thông tin hoặc liên hệ trực tiếp.
    </p>

    <div class="row justify-content-center mt-4 align-items-stretch">
        <!-- 🔹 Thông tin liên hệ -->
        <div class="col-md-5 mb-4">
            <div class="card bg-dark border-warning shadow h-100">
                <div class="card-body d-flex flex-column justify-content-center">
                    <h4 class="text-warning text-center mb-3">Thông tin liên hệ</h4>
                    <ul class="list-unstyled fs-5 mb-0">
                        <li>📍 <b>Địa chỉ:</b> 123 Nguyễn Trãi, Quận 5, TP.HCM</li>
                        <li>📞 <b>Điện thoại:</b> 0909 123 456</li>
                        <li>✉️ <b>Email:</b> support@hotelbooking.vn</li>
                        <li>⏰ <b>Giờ làm việc:</b> 8:00 - 21:00 (Thứ 2 - CN)</li>
                    </ul>
                </div>
            </div>
        </div>

        <!-- 🔹 Form gửi tin nhắn -->
        <div class="col-md-7 mb-4">
            <div class="card bg-dark border-warning shadow h-100">
                <div class="card-body">
                    <h4 class="text-warning text-center mb-3">Gửi tin nhắn cho chúng tôi</h4>

                    <form id="contactForm">
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Họ tên</label>
                                <input type="text" class="form-control bg-secondary text-light border-0" name="name" placeholder="Nhập họ tên..." required />
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Email</label>
                                <input type="email" class="form-control bg-secondary text-light border-0" name="email" placeholder="Nhập email..." required />
                            </div>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Nội dung</label>
                            <textarea class="form-control bg-secondary text-light border-0" name="message" rows="4" placeholder="Nhập nội dung..." required></textarea>
                        </div>

                        <button type="submit" class="btn btn-warning fw-bold w-100">Gửi liên hệ</button>
                    </form>
                </div>
            </div>
        </div>
    </div>

    <div class="text-center mt-5">
        <p class="text-muted">Cảm ơn bạn đã tin tưởng sử dụng dịch vụ của <strong>DoAn_HotelBooking</strong>.</p>
    </div>
</div>

<script>
    document.addEventListener("DOMContentLoaded", () => {
        const form = document.getElementById("contactForm");

        form.addEventListener("submit", (e) => {
            e.preventDefault(); // ❌ Không reload trang

            const name = form.name.value.trim();
            const email = form.email.value.trim();
            const message = form.message.value.trim();

            if (!name || !email || !message) {
                Swal.fire({
                    icon: 'error',
                    title: 'Thiếu thông tin',
                    text: 'Vui lòng điền đầy đủ họ tên, email và nội dung.',
                    confirmButtonText: "Đóng"
                });
                return;
            }

            // ✅ Hiển thị thông báo thành công
            Swal.fire({
                icon: 'success',
                title: 'Thành công',
                text: 'Cảm ơn bạn đã liên hệ! Chúng tôi sẽ phản hồi sớm nhất.',
                showConfirmButton: false,
                timer: 2000
            });

            // 🔄 Reset form
            form.reset();
        });
    });
</script>