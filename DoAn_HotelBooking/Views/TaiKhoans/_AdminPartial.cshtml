@model IEnumerable<DoAn_HotelBooking.Models.TaiKhoan>
@{
    var listAdmin = Model.Where(x => x.QuyenHan == "Admin").ToList();
}

<div class="glass-container">
    <h4 class="text-warning mb-3 fw-bold"><i class="bi bi-shield-lock-fill me-2"></i>QUẢN TRỊ VIÊN (ADMIN)</h4>

    <div class="toolbar-wrapper mb-3 d-flex justify-content-between flex-wrap gap-2">
        <div class="search-box-luxury" style="flex: 1; min-width: 300px; max-width: 500px;">
            <i class="bi bi-search"></i>
            <input type="text" id="searchAdmin" placeholder="Tìm tên, email, SĐT..." autocomplete="off">
        </div>
        <a asp-action="ExportExcel" asp-route-role="Admin" class="btn btn-excel-luxury text-decoration-none d-inline-flex align-items-center">
            <i class="bi bi-file-earmark-excel me-1"></i> Xuất Excel Admin
        </a>
    </div>

    <div class="table-responsive">
        <table class="table custom-table align-middle" id="tableAdmin">
            <thead>
                <tr>
                    <th class="text-center" style="width: 5%">#</th>
                    <th class="text-center">Họ và tên</th>
                    <th class="text-center">Email</th>
                    <th class="text-center">Số điện thoại</th>
                    <th class="text-center">Tên đăng nhập</th>
                </tr>
            </thead>
            <tbody>
                @{
                    int iAdmin = 1;
                }
                @foreach (var acc in listAdmin)
                {
                    <tr>
                        <td class="text-center text-muted fw-bold">@iAdmin</td>
                        <td class="text-center fw-bold" style="color: var(--yellow);">@acc.HoVaTen</td>
                        <td class="text-center text-light">@acc.Email</td>
                        <td class="text-center fw-semibold text-success">@acc.SoDienThoai</td>
                        <td class="text-center text-info">@acc.TenDangNhap</td>
                    </tr>
                    iAdmin++;
                }
            </tbody>
        </table>

        <!-- Khung trống -->
        <div id="noResultsAdmin" class="text-center py-4" style="display: none;">
            <i class="bi bi-search mb-2" style="font-size: 2.5rem; color: var(--yellow); opacity: 0.5;"></i>
            <h6 class="text-light">Không tìm thấy Admin nào</h6>
            <button type="button" onclick="adminTableConfig.clearSearch()" class="btn btn-outline-warning mt-2 rounded-pill px-4">
                <i class="bi bi-arrow-clockwise me-1"></i> Hiển thị tất cả
            </button>
        </div>
    </div>

    <!-- Phân trang -->
    <div class="table-footer d-flex justify-content-between align-items-center mt-3 border-top border-secondary pt-3">
        <span class="text-secondary small">Hiển thị <strong id="visibleCountAdmin" class="text-light">0</strong> / @listAdmin.Count()</span>
        <nav><ul id="paginationAdmin" class="pagination pagination-luxury mb-0"></ul></nav>
    </div>
</div>

<script>
    var adminTableConfig;
    document.addEventListener("DOMContentLoaded", function () {
        adminTableConfig = new TablePaginator({
            tableId: 'tableAdmin',
            searchInputId: 'searchAdmin',
            paginationId: 'paginationAdmin',
            visibleCountId: 'visibleCountAdmin',
            noResultsId: 'noResultsAdmin',
            rowsPerPage: 5 // Giữ nguyên 5 dòng hiển thị
        });
    });
</script>