@using Microsoft.AspNetCore.Http
@inject IHttpContextAccessor HttpContextAccessor

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - DoAn_HotelBooking - Admin</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/DoAn_HotelBooking.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/_Layout.css" />
</head>

<body>
    @{
        var quyen = Context.Session.GetString("QuyenHan");
        var maTK = Context.Session.GetInt32("ID");
        var ten = Context.Session.GetString("HoVaTen");
    }

    <!-- Đưa Overlay ra ngoài cùng, set position fixed -->
    <div class="sidebar-overlay" id="sidebarOverlay" onclick="closeSidebar()"></div>

    <div class="admin-container">

        <div class="admin-sidebar" id="adminSidebar">
            <div class="sidebar-header" style="position: relative;">
                <a href="#" class="sidebar-brand" id="sidebarBrand">
                    <i class="fas fa-hotel"></i>
                    <span>E-HOTEL ADMIN</span>
                </a>
            </div>

            <div class="sidebar-menu">
                <div class="nav-item-sidebar">
                    <a class="nav-link-sidebar" asp-controller="Home" asp-action="Index">
                        <i class="fas fa-home"></i>
                        <span>Trang chủ</span>
                    </a>
                    <a class="nav-link-sidebar" asp-controller="KhachSans" asp-action="Index">
                        <i class="fas fa-building"></i>
                        <span>Quản Lý Khách Sạn</span>
                    </a>
                </div>

                <div class="nav-item-sidebar">
                    <a class="nav-link-sidebar" asp-controller="TaiKhoans" asp-action="Index">
                        <i class="fas fa-users"></i>
                        <span>Quản Lý Tài Khoản</span>
                    </a>
                </div>

                <div class="nav-item-sidebar">
                    <a class="nav-link-sidebar" asp-controller="BaoCao" asp-action="Index">
                        <i class="fas fa-chart-bar"></i>
                        <span>Báo Cáo & Thống Kê</span>
                    </a>
                </div>

                <div class="nav-item-sidebar">
                    <a class="nav-link-sidebar" asp-controller="KhachSans" asp-action="BanDo">
                        <i class="fas fa-map-marked-alt"></i>
                        <span>Bản Đồ Khách Sạn</span>
                    </a>
                </div>
            </div>
        </div>

        <div class="admin-main" id="adminMain">
            <header class="admin-header">
                <div class="d-flex align-items-center gap-3">
                    <button class="header-toggle-btn" onclick="toggleSidebar()">
                        <i class="fas fa-bars"></i>
                    </button>
                    <a class="navbar-brand text-light fw-bold m-0" asp-area="" asp-controller="Home" asp-action="Index">
                        Bảng điều khiển hệ thống
                    </a>
                </div>

                <div class="navbar-nav flex-row">
                    <li class="nav-item d-flex align-items-center">
                        <a href="javascript:void(0);" class="nav-link text-light px-3 py-2" onclick="showDetail(@HttpContextAccessor.HttpContext.Session.GetInt32("ID"))">
                            <i class="fas fa-user-circle me-2 text-warning"></i> @HttpContextAccessor.HttpContext.Session.GetString("HoVaTen")
                        </a>
                        <span class="text-secondary mx-2">|</span>
                        <a class="nav-link text-light" href="javascript:void(0)" onclick="confirmLogoutSwal('@Url.Action("DangXuat", "DangKy_DangNhap")')">
                            Đăng xuất
                        </a>
                    </li>
                </div>
            </header>

            <main role="main" class="container flex-grow-1 pb-4">
                @RenderBody()
            </main>
        </div>

    </div>

    <input type="hidden" id="successMessage" value="@TempData["SuccessMessage"]" />
    <input type="hidden" id="errorMessage" value="@TempData["ErrorMessage"]" />

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="~/js/Share/DoiMatKhau.js"></script>
    <script src="~/js/Share/SideBar.js"></script>
    <script src="~/js/Share/ThongTinChiTiet.js"></script>
    <script src="~/js/Share/DoiMatKhau.js"></script>
    <script src="~/js/Share/DangXuat.js"></script>
    <script src="~/js/Share/Success.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>