@using Microsoft.AspNetCore.Http
@using DoAn_HotelBooking.Data
@inject DoAn_HotelBookingContext _context
@inject IHttpContextAccessor HttpContextAccessor

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Quản lý Khách sạn</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link href="~/css/_Layout.css" rel="stylesheet" asp-append-version="true" />
    <link rel="stylesheet" href="~/DoAn_HotelBooking.styles.css" asp-append-version="true" />
</head>

<body>
    @{
        var quyen = Context.Session.GetString("QuyenHan");
        var maTK = Context.Session.GetInt32("ID");
        var maKS = Context.Session.GetString("MaKhachSan");
        var ten = Context.Session.GetString("HoVaTen");
        var tenKhachSan = Context.Session.GetString("TenKhachSan") ?? "Khách sạn";

        int soThongBaoMoi = 0;

        if (!string.IsNullOrEmpty(maKS))
        {
            soThongBaoMoi = _context.ThongBao.Count(t => t.MaKhachSan == maKS && t.DaDoc == false);
        }
    }

    <div class="admin-container">
        <div class="sidebar-overlay" id="sidebarOverlay" onclick="closeSidebar()"></div>

        <div class="admin-sidebar" id="adminSidebar">
            <div class="sidebar-header">
                <a href="#" class="sidebar-brand" id="sidebarBrand">
                    <i class="fas fa-hotel"></i>
                    <span>@maKS</span>
                </a>
            </div>

            <div class="sidebar-menu">
                <div class="nav-item-sidebar">
                    <a class="nav-link-sidebar" asp-controller="Home" asp-action="Index">
                        <i class="fas fa-home"></i>
                        <span>Trang chủ</span>
                    </a>
                    <a class="nav-link-sidebar" asp-controller="Phongs" asp-action="Index" asp-route-id="@maKS">
                        <i class="fas fa-bed"></i>
                        <span>Quản lý Phòng</span>
                    </a>
                </div>

                <div class="nav-item-sidebar">
                    <a class="nav-link-sidebar" asp-controller="TaiKhoans" asp-action="Index" asp-route-maKhachSan="@maKS">
                        <i class="fas fa-users"></i>
                        <span>Quản lý Tài khoản</span>
                    </a>
                </div>

                <div class="nav-item-sidebar">
                    <a class="nav-link-sidebar" asp-controller="DatPhongs" asp-action="Index" asp-route-maKhachSan="@maKS">
                        <i class="fas fa-calendar-check"></i>
                        <span>Đặt phòng</span>
                    </a>
                </div>

                <div class="nav-item-sidebar">
                    <a class="nav-link-sidebar" asp-controller="DatPhongs" asp-action="DangLuuTru" asp-route-maKhachSan="@maKS">
                        <i class="fas fa-door-open"></i>
                        <span>Đang lưu trú</span>
                    </a>
                </div>

                <div class="nav-item-sidebar">
                    <a class="nav-link-sidebar" asp-controller="DatPhongs" asp-action="HoaDon" asp-route-maKhachSan="@maKS">
                        <i class="fas fa-file-invoice-dollar"></i>
                        <span>Hóa đơn</span>
                    </a>
                </div>

                <div class="nav-item-sidebar">
                    <a class="nav-link-sidebar" asp-controller="KhachSans" asp-action="BanDo">
                        <i class="fas fa-map-marked-alt"></i>
                        <span>Bản Đồ Khách Sạn</span>
                    </a>
                </div>
            </div>
        </div>

        <div class="admin-main" id="adminMain">
            <div class="admin-main-content d-flex flex-column h-100">
                <header class="admin-header">
                    <div class="d-flex align-items-center gap-3">
                        <button class="header-toggle-btn" onclick="toggleSidebar()">
                            <i class="fas fa-bars"></i>
                        </button>
                        <a class="navbar-brand text-light fw-bold m-0" asp-area="" asp-controller="Home" asp-action="Index">
                            <i class="fas fa-building text-warning me-2"></i> @tenKhachSan
                        </a>
                    </div>

                    <div class="navbar-nav flex-row align-items-center">

                        <div class="position-relative me-2 d-flex align-items-center">
                            <a href="#"
                               class="btn-noti position-relative"
                               data-bs-toggle="modal"
                               data-bs-target="#thongBaoModal">

                                <i class="fas fa-bell fs-5"></i>

                                @if (soThongBaoMoi > 0)
                                {
                                    <span class="position-absolute top-0 start-100 translate-middle noti-dot"></span>
                                }
                            </a>
                        </div>

                        <li class="nav-item d-flex align-items-center">
                            <a href="javascript:void(0);" class="nav-link text-light px-3 py-2"
                               onclick="showDetail(
                                   @maTK,
                                   '@Url.Action("DetailsJson", "TaiKhoans")',
                                   '@quyen',
                                   '@tenKhachSan'
                               )">
                                <i class="fas fa-user-circle me-2 text-warning"></i> @ten
                            </a>
                            <span class="text-secondary mx-2">|</span>
                            <a class="nav-link text-light" href="javascript:void(0)" onclick="confirmLogoutSwal('@Url.Action("DangXuat", "DangKy_DangNhap")')">
                                Đăng xuất
                            </a>
                        </li>
                    </div>
                </header>

                <main role="main" class="container flex-grow-1 pb-4">
                    @RenderBody()
                </main>
            </div>
        </div>
    </div>

    <div class="modal fade" id="thongBaoModal" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered modal-lg">
            <div class="modal-content">

                <div class="modal-header">
                    <h5 class="modal-title">
                        <i class="fas fa-bell text-warning"></i>
                        Thông báo
                    </h5>

                    <button type="button"
                            class="btn-close"
                            data-bs-dismiss="modal">
                    </button>
                </div>

                <div class="modal-body" id="thongBaoBody">

                    <div class="text-center py-4">
                        <div class="spinner-border text-warning"></div>
                    </div>

                </div>

            </div>
        </div>
    </div>

    <input type="hidden" id="successMessage" value="@TempData["SuccessMessage"]" />
    <input type="hidden" id="errorMessage" value="@TempData["ErrorMessage"]" />

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="~/js/Share/DoiMatKhau.js" asp-append-version="true"></script>
    <script src="~/js/Share/DangXuat.js" asp-append-version="true"></script>
    <script src="~/js/Share/SideBar.js" asp-append-version="true"></script>
    <script src="~/js/Share/ThongTinChiTiet.js" asp-append-version="true"></script>
    <script src="~/js/Share/ThongBao.js" asp-append-version="true"></script>
    <script src="~/js/Share/Success.js" asp-append-version="true"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>