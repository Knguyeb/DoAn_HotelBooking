@model IEnumerable<DoAn_HotelBooking.Models.ThongBao>

@{
    ViewData["Title"] = "Tất cả thông báo";

    Layout = "~/Views/Shared/_LayoutQLNV.cshtml";

    // Đếm số liệu thống kê
    int totalCount = Model?.Count() ?? 0;
    int unreadCount = Model?.Count(t => !t.DaDoc) ?? 0;
}

<link rel="stylesheet" href="~/css/KhachSan/Index.css" asp-append-version="true" />
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">

<div class="container-fluid fade-in-up mt-4">
    @Html.AntiForgeryToken()

    <div class="row mb-4 g-3 align-items-stretch">
        <div class="col-md-4">
            <div class="stat-card h-100 d-flex align-items-center">
                <div class="stat-icon" style="background: linear-gradient(135deg, #FFD700, #FF4500);">
                    <i class="bi bi-bell-fill"></i>
                </div>
                <div class="stat-info">
                    <h6>Thông Báo Chưa Đọc</h6>
                    <h3 id="totalCount" class="@(unreadCount > 0 ? "text-warning" : "text-light")">
                        @unreadCount <span class="text-secondary fs-6 fw-normal">/ @totalCount tổng</span>
                    </h3>
                </div>
            </div>
        </div>

        <div class="col-md-8">
            <div class="stat-card h-100 d-flex align-items-center justify-content-between">
                <div>
                    <h2 class="page-title mb-1">DANH SÁCH THÔNG BÁO</h2>
                    <p class="text-secondary mb-0 small">Lịch sử các hoạt động đặt phòng, hủy phòng và hệ thống</p>
                </div>
                <div class="d-flex gap-2">
                    <button type="button" onclick="location.reload()" class="btn btn-primary-luxury text-decoration-none d-flex align-items-center">
                        <i class="bi bi-arrow-clockwise me-2"></i> Tải lại
                    </button>

                    <button type="button" class="btn btn-excel-luxury text-decoration-none d-flex align-items-center" onclick="markAllAsRead()">
                        <i class="bi bi-check-all me-2 fs-5"></i> Đánh dấu đã đọc tất cả
                    </button>
                </div>
            </div>
        </div>
    </div>

    <div class="glass-container">
        <div class="toolbar-wrapper mb-3">
            <div class="search-box-luxury">
                <i class="bi bi-search"></i>
                <input type="text" id="searchNotification" placeholder="Tìm kiếm nội dung thông báo..." autocomplete="off">
            </div>
        </div>

        <div class="table-responsive">
            <table class="table custom-table align-middle" id="notificationTable">
                <thead>
                    <tr>
                        <th class="text-center" style="width: 5%">#</th>
                        <th class="text-start" style="width: 55%">Nội dung thông báo</th>
                        <th class="text-center">Thời gian</th>
                        <th class="text-center">Trạng thái</th>
                    </tr>
                </thead>
                <tbody>
                    @{
                        int i = 1;
                    }
                    @if (Model != null)
                    {
                        @foreach (var item in Model)
                        {
                            // Logic đổi icon theo nội dung
                            string iconClass = "bi-bell-fill text-warning";
                            string noiDungLower = item.NoiDung?.ToLower() ?? "";

                            if (noiDungLower.Contains("hủy")) iconClass = "bi-calendar-x-fill text-danger";
                            else if (noiDungLower.Contains("đặt")) iconClass = "bi-calendar-check-fill text-success";
                            else if (noiDungLower.Contains("thanh toán")) iconClass = "bi-receipt-cutoff text-info";

                            <tr>
                                <td class="text-center text-muted fw-bold">@i</td>

                                <td class="text-start">
                                    <div class="d-flex align-items-center gap-3">
                                        <div class="fs-4" style="width: 30px; text-align:center;">
                                            <i class="bi @iconClass"></i>
                                        </div>
                                        <div class="fw-bold text-light" style="font-size: 1.05rem; letter-spacing: 0.3px;">
                                            @item.NoiDung
                                        </div>
                                    </div>
                                </td>

                                <td class="text-center text-muted small fw-semibold">
                                    <i class="bi bi-clock me-1"></i> @item.NgayTao.ToString("dd/MM/yyyy HH:mm")
                                </td>

                                <td class="text-center">
                                    @if (item.DaDoc)
                                    {
                                        <span class="badge bg-secondary opacity-75 rounded-pill px-3 py-2"><i class="bi bi-check2"></i> Đã đọc</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-warning text-dark rounded-pill px-3 py-2"><i class="bi bi-envelope-exclamation"></i> Mới</span>
                                    }
                                </td>
                            </tr>
                            i++;
                        }
                    }
                </tbody>
            </table>

            <div id="noResults" class="text-center py-5" style="display: none;">
                <div class="mb-3">
                    <i class="bi bi-bell-slash" style="font-size: 3rem; color: var(--yellow); opacity: 0.5;"></i>
                </div>
                <h5 class="text-light">Không có thông báo nào</h5>
                <p class="text-secondary">Bạn hiện không có thông báo hoặc không tìm thấy kết quả phù hợp.</p>
                <button type="button" onclick="pageConfig.clearSearch()" class="btn btn-outline-warning mt-2 rounded-pill px-4">
                    <i class="bi bi-arrow-clockwise me-1"></i> Hiển thị tất cả
                </button>
            </div>
        </div>

        <div class="table-footer d-flex justify-content-between align-items-center mt-auto pt-3" style="border-top: 1px solid var(--border-color)">
            <span class="text-secondary small">Đang hiển thị <strong id="visibleCount" class="text-light">0</strong> thông báo</span>
            <ul id="pagination" class="pagination-luxury">
            </ul>
        </div>
    </div>
</div>

@section Scripts {
    <input type="hidden" id="successMessage" value="@TempData["SuccessMessage"]" />
    <input type="hidden" id="errorMessage" value="@TempData["ErrorMessage"]" />

    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="~/js/Share/Delete.js" asp-append-version="true"></script>
    <script src="~/js/Share/Success.js" asp-append-version="true"></script>
    <script src="~/js/Share/PhanTrang.js" asp-append-version="true"></script>

    <script>
        var pageConfig;
        document.addEventListener("DOMContentLoaded", function () {
            // Khởi tạo phân trang y hệt file mẫu nhưng thay ID cho bảng thông báo
            pageConfig = new TablePaginator({
                tableId: 'notificationTable',
                searchInputId: 'searchNotification',
                paginationId: 'pagination',
                visibleCountId: 'visibleCount',
                noResultsId: 'noResults',
                rowsPerPage: 20
            });
        });

        // Hàm gọi AJAX để đánh dấu tất cả đã đọc
        function markAllAsRead() {
            $.ajax({
                url: '/ThongBao/DanhDauDaDocToanBo', // Đảm bảo Controller của bạn tên là ThongBaos hay ThongBao
                type: 'POST',
                success: function (res) {
                    if (res.success) {
                        Swal.fire({
                            icon: 'success',
                            title: 'Thành công!',
                            text: 'Đã đánh dấu tất cả thông báo là đã đọc.',
                            background: '#242526',
                            color: '#fff',
                            showConfirmButton: false,
                            timer: 1500
                        }).then(() => {
                            location.reload(); // Tải lại trang để cập nhật UI
                        });
                    }
                },
                error: function () {
                    Swal.fire({
                        icon: 'error',
                        title: 'Lỗi!',
                        text: 'Không thể cập nhật thông báo.',
                        background: '#242526',
                        color: '#fff',
                        confirmButtonColor: '#FF4500'
                    });
                }
            });
        }
    </script>
}