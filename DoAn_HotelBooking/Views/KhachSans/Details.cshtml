@model DoAn_HotelBooking.Models.KhachSan

@{
    ViewData["Title"] = "Chi tiết khách sạn";
}

<!-- Ép tải lại CSS mới nhất để tránh lỗi cache -->
<link rel="stylesheet" href="~/css/KhachSan/Details.css" asp-append-version="true" />
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">
<link rel="stylesheet" href="https://unpkg.com/leaflet/dist/leaflet.css" />

@{
    var quyen = Context.Session.GetString("QuyenHan");

    // Ép kiểu danh sách phòng để tính giá trung bình
    var phongs = ViewBag.Phongs as List<DoAn_HotelBooking.Models.Phong>;
    double giaTrungBinh = 0;

    if (phongs != null && phongs.Any())
    {
        try
        {
            giaTrungBinh = phongs.Average(p => Convert.ToDouble(p.GiaPhong));
        }
        catch { }
    }
}

<div class="details-container container">
    <div class="card details-card">

        <!-- Tiêu đề chính -->
        <h1 class="mb-5 text-center text-uppercase">@Model.TenKhachSan</h1>

        <div class="row g-5">
            <!-- ================= CỘT ẢNH ================= -->
            <div class="col-lg-5 text-center">
                @if (!string.IsNullOrEmpty(Model.HinhAnh))
                {
                    var anhList = Model.HinhAnh.Split(";");

                    <div id="hotelCarousel" class="carousel slide shadow-lg" data-bs-ride="carousel" data-bs-interval="3000" style="border-radius: 15px; overflow: hidden;">
                        <div class="carousel-indicators">
                            @for (int i = 0; i < anhList.Length; i++)
                            {
                                <button type="button" data-bs-target="#hotelCarousel" data-bs-slide-to="@i" class="@(i == 0 ? "active" : "")" aria-current="@(i == 0 ? "true" : "false")"></button>
                            }
                        </div>

                        <div class="carousel-inner">
                            @for (int i = 0; i < anhList.Length; i++)
                            {
                                <div class="carousel-item @(i == 0 ? "active" : "")">
                                    <img src="@anhList[i]" alt="Ảnh khách sạn" class="d-block w-100 img-fluid" style="height: 350px; object-fit: cover;" />
                                </div>
                            }
                        </div>

                        <button class="carousel-control-prev" type="button" data-bs-target="#hotelCarousel" data-bs-slide="prev">
                            <span class="carousel-control-prev-icon" aria-hidden="true"></span>
                            <span class="visually-hidden">Previous</span>
                        </button>
                        <button class="carousel-control-next" type="button" data-bs-target="#hotelCarousel" data-bs-slide="next">
                            <span class="carousel-control-next-icon" aria-hidden="true"></span>
                            <span class="visually-hidden">Next</span>
                        </button>
                    </div>
                }
                else
                {
                    <div class="d-flex align-items-center justify-content-center" style="height: 350px; background: rgba(0,0,0,0.2); border-radius: 15px;">
                        <p class="text-muted"><i class="fas fa-image fa-2x mb-2 d-block"></i> Chưa có hình ảnh</p>
                    </div>
                }
            </div>

            <!-- ================= CỘT THÔNG TIN ================= -->
            <div class="col-lg-7 d-flex flex-column justify-content-between">
                <div>
                    <dl class="row align-items-center m-0" style="row-gap: 15px;">
                        <dt class="col-sm-4 mb-0"><i class="fas fa-building text-warning me-2"></i> Tên khách sạn</dt>
                        <dd class="col-sm-8 mb-0 fs-5 fw-bold text-warning">@Model.TenKhachSan</dd>

                        <dt class="col-sm-4 mb-0"><i class="fas fa-map-marker-alt text-danger me-2"></i> Địa chỉ</dt>
                        <dd class="col-sm-8 mb-0">@Model.DiaChi</dd>

                        <dt class="col-sm-4 mb-0"><i class="fas fa-phone-alt text-success me-2"></i> Điện thoại</dt>
                        <dd class="col-sm-8 mb-0">@Model.SoDienThoai</dd>

                        <dt class="col-sm-4 mb-0"><i class="fas fa-star text-warning me-2"></i> Đánh giá</dt>
                        <dd class="col-sm-8 mb-0 d-flex align-items-center">
                            @if (ViewBag.TrungBinhSao > 0)
                            {
                                <span class="badge bg-warning text-dark fs-6 py-2 px-3 shadow-sm">
                                    <i class="fas fa-star"></i> @ViewBag.TrungBinhSao / 5
                                </span>
                                <small class="text-muted ms-2 fst-italic">(@ViewBag.SoDanhGia đánh giá)</small>
                            }
                            else
                            {
                                <span class="badge bg-secondary fs-6 py-2 px-3">Chưa có đánh giá</span>
                            }
                        </dd>

                        <dt class="col-sm-4 mb-0"><i class="fas fa-tags text-info me-2"></i> Giá trung bình</dt>
                        <dd class="col-sm-8 mb-0 d-flex align-items-center">
                            @if (giaTrungBinh > 0)
                            {
                                <div class="dropup">
                                    <span class="text-success fw-bold fs-5 dropdown-toggle"
                                          data-bs-toggle="dropdown"
                                          aria-expanded="false"
                                          data-base-price="@giaTrungBinh"
                                          style="cursor: pointer;"
                                          title="Nhấn để đổi tiền tệ">
                                        @Convert.ToDouble(giaTrungBinh).ToString("N0") VNĐ
                                    </span>
                                    <ul class="dropdown-menu dropdown-menu-dark shadow-lg mt-2" aria-labelledby="priceDisplay" style="border: 1px solid rgba(255,255,255,0.1); border-radius: 12px;">
                                        <li><a class="dropdown-item currency-option" href="javascript:void(0)" data-currency="VND">🇻🇳 VNĐ</a></li>
                                        <li><a class="dropdown-item currency-option" href="javascript:void(0)" data-currency="USD">🇺🇸 USD</a></li>
                                        <li><a class="dropdown-item currency-option" href="javascript:void(0)" data-currency="EUR">🇪🇺 EUR</a></li>
                                    </ul>
                                </div>
                                <small class="text-muted ms-2"> / đêm</small>
                            }
                            else
                            {
                                <span class="text-muted fst-italic">Đang cập nhật</span>
                            }
                        </dd>
                    </dl>
                </div>

                <!-- ================= CÁC NÚT THAO TÁC ĐÃ ĐƯA LÊN ĐÂY ================= -->
                <div class="custom-box d-flex justify-content-between align-items-center mt-4 pt-3" style="border-top: 1px dashed rgba(255,255,255,0.1);">
                    <div>
                        <a class="btnQuayLai" href="javascript:void(0)" onclick="history.back()">
                            <i class="fas fa-arrow-left me-2"></i> Quay lại
                        </a>
                    </div>

                    <div class="d-flex gap-3">
                        @if (quyen == "Admin")
                        {
                            <a class="btnSua"
                               asp-action="Edit"
                               asp-route-id="@Model?.MaKhachSan">
                                <i class="fas fa-edit me-2"></i> Sửa
                            </a>
                        }
                        else if (quyen == "Khách hàng")
                        {
                            <a id="btnDanhGia"
                               class="btnDanhGia"
                               data-maKhachSan="@Model.MaKhachSan"
                               href="javascript:void(0)">
                                <i class="fas fa-star me-2"></i> Đánh giá
                            </a>
                        }
                    </div>
                </div>
            </div>
        </div>

        <!-- ================= DANH SÁCH PHÒNG (DẠNG CARD) ================= -->
        <div class="mt-5 pt-4" style="border-top: 1px dashed rgba(255, 215, 0, 0.3);">
            <h3 class="text-warning fs-4 mb-4"><i class="fas fa-fire text-danger me-2"></i> Top 3 Phòng Đánh Giá Cao Nhất</h3>

            @if (phongs != null && phongs.Any())
            {
                <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
                    @foreach (var item in phongs)
                    {
                        <div class="col">
                            <div class="card room-card h-100">

                                <div class="position-relative overflow-hidden" style="border-radius: 15px 15px 0 0;">
                                    @{
                                        var roomImg = (item.HinhAnh ?? "").Split(';', StringSplitOptions.RemoveEmptyEntries).FirstOrDefault()?.Trim();
                                        string imgSrc = string.IsNullOrEmpty(roomImg) ? Url.Content("~/Images/no-image.png") :
                                        (roomImg.StartsWith("/") ? Url.Content("~" + roomImg) : Url.Content("~/Images/" + roomImg));

                                        // Xử lý 3 trạng thái
                                        string trangThai = item.TrangThai ?? "";
                                        string badgeText = trangThai;
                                        string badgeStyle = "background-color: rgba(108, 117, 125, 0.9); color: white;"; // Mặc định (Xám)
                                        string badgeIcon = "bi-info-circle-fill"; // Icon mặc định

                                        if (trangThai == "Còn trống")
                                        {
                                            badgeStyle = "background-color: rgba(40, 167, 69, 0.95); color: #fff; box-shadow: 0 4px 10px rgba(40,167,69,0.3);";
                                            badgeIcon = "bi-check-circle-fill"; // Icon dấu tick check
                                        }
                                        else if (trangThai == "Đã đặt")
                                        {
                                            badgeStyle = "background-color: rgba(220, 53, 69, 0.95); color: #fff; box-shadow: 0 4px 10px rgba(220,53,69,0.3);";
                                            badgeIcon = "bi-door-closed-fill"; // Icon cửa đóng
                                        }
                                        else if (trangThai == "Bảo trì")
                                        {
                                            badgeStyle = "background-color: rgba(255, 193, 7, 0.95); color: #000; box-shadow: 0 4px 10px rgba(255,193,7,0.3);";
                                            badgeIcon = "bi-tools"; // Icon dụng cụ sửa chữa
                                        }
                                    }

                                    <img src="@imgSrc" class="card-img-top" alt="Phòng @item.SoPhong" style="height: 220px; object-fit: cover; transition: transform 0.3s ease;">

                                    <!-- Tem trạng thái (Badge) đã tích hợp Icon -->
                                    <span class="badge position-absolute top-0 end-0 m-3" style="@badgeStyle font-size: 0.85rem; padding: 8px 15px; border-radius: 8px; backdrop-filter: blur(4px); font-weight: 600;">
                                        <i class="bi @badgeIcon me-1"></i> @badgeText
                                    </span>
                                </div>

                                <div class="card-body d-flex flex-column text-white">

                                    <h5 class="card-title text-warning fw-bold mb-4 text-center">
                                        <i class="fas fa-bed me-2"></i> Phòng @item.SoPhong
                                    </h5>

                                    <div class="d-flex justify-content-between align-items-center mb-4 pb-3" style="border-bottom: 1px dashed rgba(255,255,255,0.1);">
                                        <div class="text-muted">
                                            <i class="fas fa-layer-group text-secondary me-1"></i> Loại:
                                            <strong class="text-light">@(item.LoaiPhong ?? "Đang cập nhật")</strong>
                                        </div>

                                        <div>
                                            @if (item.TrungBinhSao > 0)
                                            {
                                                <span class="badge bg-warning text-dark shadow-sm px-2 py-1" style="font-size: 0.9rem;">
                                                    <i class="fas fa-star"></i> @item.TrungBinhSao.ToString("0.0")
                                                </span>
                                                <small class="text-muted ms-2 fst-italic">(@ViewBag.SoDanhGia đánh giá)</small>
                                            }
                                            else
                                            {
                                                <span class="badge bg-secondary shadow-sm px-2 py-1" style="font-size: 0.85rem; font-weight: normal;">
                                                    Chưa đánh giá
                                                </span>
                                            }
                                        </div>
                                    </div>

                                    <div class="mt-auto d-flex align-items-center gap-2">
                                        <span class="text-info"><i class="fas fa-tag me-1"></i> Giá:</span>

                                        <div class="dropdown">
                                            <span class="text-success fw-bold fs-5 dropdown-toggle"
                                                  data-bs-toggle="dropdown"
                                                  aria-expanded="false"
                                                  data-base-price="@item.GiaPhong"
                                                  style="cursor: pointer;"
                                                  title="Nhấn để đổi tiền tệ">
                                                @Convert.ToDouble(@item.GiaPhong).ToString("N0") VNĐ
                                            </span>
                                            <ul class="dropdown-menu dropdown-menu-dark shadow-lg mt-2" style="border: 1px solid rgba(255,255,255,0.1); border-radius: 12px;">
                                                <li><a class="dropdown-item currency-option" href="javascript:void(0)" data-currency="VND">🇻🇳 VNĐ</a></li>
                                                <li><a class="dropdown-item currency-option" href="javascript:void(0)" data-currency="USD">🇺🇸 USD</a></li>
                                                <li><a class="dropdown-item currency-option" href="javascript:void(0)" data-currency="EUR">🇪🇺 EUR</a></li>
                                            </ul>
                                        </div>

                                        <small class="text-muted"> / đêm</small>
                                    </div>
                                </div>

                                <div class="card-footer bg-transparent border-0 p-3 pt-0">
                                    <button type="button"
                                            class="btn btn-outline-warning w-100 btn-xem-chi-tiet-phong"
                                            style="border-radius: 30px; font-weight: bold;"
                                            data-bs-toggle="modal"
                                            data-bs-target="#dynamicAjaxModal"
                                            data-id="@item.ID"
                                            data-title="Phòng @item.SoPhong"
                                            data-url="@Url.Action("DetailsPartial", "Phongs", new { id = item.ID })">
                                        Xem chi tiết <i class="fas fa-arrow-right ms-1"></i>
                                    </button>
                                </div>

                            </div>
                        </div>
                    }
                </div>

                <div class="text-center mt-5">
                    <a asp-controller="Phongs"
                       asp-action="TatCaPhong"
                       asp-route-maKhachSan="@Model.MaKhachSan"
                       class="btnXemTatCa">
                        Xem tất cả phòng của khách sạn <i class="fas fa-arrow-right ms-2"></i>
                    </a>
                </div>
            }
            else
            {
                <p class="text-muted fst-italic"><i class="fas fa-info-circle me-1"></i> Chưa có phòng nào cho khách sạn này.</p>
            }
        </div>

        <!-- ================= BẢN ĐỒ OPENSTREETMAP ================= -->
        <div class="mt-5 pt-4" style="border-top: 1px dashed rgba(255, 215, 0, 0.3);">
            <h3 class="text-center text-warning mb-4"><i class="fas fa-map-marked-alt me-2"></i> Vị trí trên bản đồ</h3>
            <div id="map" style="height: 400px; border: 1px solid rgba(255, 215, 0, 0.3); border-radius: 15px;" class="shadow-lg"></div>
        </div>
    </div>
</div>

<!-- Modal Chi tiết phòng -->
<div class="modal fade" id="dynamicAjaxModal" tabindex="-1" aria-labelledby="dynamicAjaxModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered modal-dialog-scrollable">
        <div class="modal-content custom-modal-bg text-light" style="border: 1px solid rgba(255, 215, 0, 0.2); border-radius: 15px;">
            <div class="modal-header border-bottom-0 pb-0">
                <h5 class="modal-title text-warning fw-bold" id="dynamicAjaxModalLabel">
                    <div class="spinner-border spinner-border-sm text-warning me-2" role="status"></div> Đang tải...
                </h5>
                <button type="button" class="btn-close btn-close-white opacity-75" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>

            <div class="modal-body pt-3 pb-4">
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/leaflet@1.9.4/dist/leaflet.js"></script>
    <script src="~/js/share/doitien.js"></script>
    <script src="~/js/danhgia/danggiaks.js" asp-append-version="true"></script>
    <script src="~/js/danhgia/danhgiaphong.js" asp-append-version="true"></script>
    <script src="~/js/share/popupdetails.js"></script>
    <script>
        document.addEventListener("DOMContentLoaded", () => {
            const mapContainer = document.getElementById("map");

            const hotelName = "@(Model.TenKhachSan ?? "Khách sạn")";
            const address = "@(Model.DiaChi ?? "")";
            const lat = parseFloat("@(Model.ViDo ?? "0")");
            const lon = parseFloat("@(Model.KinhDo ?? "0")");

            if (!lat || !lon || lat === 0 || lon === 0) {
                mapContainer.innerHTML = "<div class='h-100 d-flex align-items-center justify-content-center bg-dark rounded'><p class='text-muted text-center m-0'><i class='fas fa-exclamation-triangle text-warning me-2'></i> Chưa có tọa độ hợp lệ để hiển thị bản đồ.</p></div>";
                return;
            }

            const map = L.map("map").setView([lat, lon], 15);
            L.tileLayer("https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png", {
                maxZoom: 18,
                attribution: '&copy; <a href="https://www.openstreetmap.org/">OpenStreetMap</a>'
            }).addTo(map);

            const customIcon = L.divIcon({
                className: 'custom-div-icon',
                html: `
                    <div style="display: flex; flex-direction: column; align-items: center; filter: drop-shadow(0px 5px 10px rgba(255, 69, 0, 0.6));">
                        <div style="background-color: #FF4500; width: 40px; height: 40px; border-radius: 50%; border: 3px solid #FFF; display: flex; align-items: center; justify-content: center; color: white; font-size: 18px;">
                            <i class="fas fa-hotel"></i>
                        </div>
                        <div style="width: 0; height: 0; border-left: 8px solid transparent; border-right: 8px solid transparent; border-top: 12px solid #FFF; margin-top: -2px;"></div>
                    </div>
                `,
                iconSize: [40, 52],
                iconAnchor: [20, 52],
                popupAnchor: [0, -45]
            });

            L.marker([lat, lon], {icon: customIcon})
                .addTo(map)
                .bindPopup(`
                    <div style="text-align:center; padding: 10px 5px 15px 5px;">
                        <strong style="font-size:16px; color: #FF4500; display:block; margin-bottom: 5px;">${hotelName}</strong>
                        <span style="font-size:13px; color: #fff; display:block; margin-bottom: 8px;">${address}</span>
                        <a href="https://www.google.com/maps/dir/?api=1&destination=${lat},${lon}"
                           target="_blank"
                           style="display: inline-block; margin-top: 12px; background: #FF4500; color: #fff; padding: 8px 18px; border-radius: 20px; text-decoration: none; font-size: 13px; font-weight: 600; box-shadow: 0 4px 10px rgba(255, 69, 0, 0.4);">
                            <i class="fas fa-directions me-1"></i> Chỉ đường
                        </a>
                    </div>
                `)
                .openPopup();
        });
    </script>
}