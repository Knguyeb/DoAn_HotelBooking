@using System.Globalization
@model DoAn_HotelBooking.Models.Phong

@{
    ViewData["Title"] = "Cập nhật phòng";
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">
<link rel="stylesheet" href="~/css/KhachSan/Create.css" asp-append-version="true" />

<div class="container-fluid fade-in-up py-5 px-4">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h4 class="text-subtitle">QUẢN LÝ PHÒNG</h4>
            <h2 class="page-title">CHỈNH SỬA THÔNG TIN PHÒNG (@ViewBag.KhachSan.TenKhachSan)</h2>
        </div>
        <a class="btn btn-back-luxury" asp-action="Index" asp-route-id="@Model.MaKhachSan">
            <i class="bi bi-arrow-left me-2"></i> Quay lại
        </a>
    </div>

    <div class="glass-form-container">
        <form asp-action="Edit" method="post" enctype="multipart/form-data" id="editForm">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="ID" />
            <input type="hidden" asp-for="MaKhachSan" />

            <div class="row g-5">

                <div class="col-12">
                    <h5 class="section-header"><i class="bi bi-info-circle-fill me-2"></i>Thông tin chung</h5>

                    <div class="row g-4">
                        <div class="col-md-6 col-lg-3">
                            <label asp-for="SoPhong" class="form-label-luxury">Số phòng <span class="text-danger">*</span></label>
                            <div class="input-group luxury-input-group">
                                <span class="input-group-text"><i class="bi bi-door-closed-fill"></i></span>
                                <input asp-for="SoPhong" class="form-control" placeholder="VD: 101" required />
                            </div>
                            <span asp-validation-for="SoPhong" class="text-danger small fw-bold"></span>
                        </div>

                        <div class="col-md-6 col-lg-3">
                            <label asp-for="Tang" class="form-label-luxury">Tầng <span class="text-danger">*</span></label>
                            <div class="input-group luxury-input-group">
                                <span class="input-group-text"><i class="bi bi-building"></i></span>
                                <input asp-for="Tang" class="form-control" placeholder="VD: 1" required />
                            </div>
                            <span asp-validation-for="Tang" class="text-danger small fw-bold"></span>
                        </div>

                        <div class="col-md-6 col-lg-3">
                            <label asp-for="SucChua" class="form-label-luxury">Sức chứa <span class="text-danger">*</span></label>
                            <div class="input-group luxury-input-group">
                                <span class="input-group-text"><i class="bi bi-people-fill"></i></span>
                                <input asp-for="SucChua" type="number" class="form-control" placeholder="Số người" required min="1" />
                            </div>
                            <span asp-validation-for="SucChua" class="text-danger small fw-bold"></span>
                        </div>

                        <div class="col-md-6 col-lg-3">
                            <label asp-for="LoaiPhong" class="form-label-luxury">Loại phòng <span class="text-danger">*</span></label>
                            <div class="input-group luxury-input-group">
                                <span class="input-group-text"><i class="bi bi-star-fill"></i></span>
                                <select asp-for="LoaiPhong" class="form-control luxury-dropdown">
                                    <option value="">-- Loại phòng --</option>
                                    <option value="Standard">Standard</option>
                                    <option value="Deluxe">Deluxe</option>
                                    <option value="VIP">VIP</option>
                                </select>
                            </div>
                            <span asp-validation-for="LoaiPhong" class="text-danger small"></span>
                        </div>

                        <div class="col-md-12 col-lg-5">
                            <label asp-for="GiaPhong" class="form-label-luxury">Giá phòng / đêm (VNĐ) <span class="text-danger">*</span></label>
                            <div class="input-group luxury-input-group">
                                <span class="input-group-text"><i class="bi bi-cash"></i></span>
                                <input id="GiaPhongDisplay" type="text" inputmode="numeric" class="form-control" placeholder="Nhập giá phòng..." value="@(Model?.GiaPhong.ToString("N0", CultureInfo.GetCultureInfo("vi-VN")) ?? "")" />
                                <input type="hidden" asp-for="GiaPhong" id="GiaPhong" />
                            </div>
                            <span asp-validation-for="GiaPhong" class="text-danger small fw-bold"></span>
                        </div>

                        <div class="col-md-12 col-lg-7">
                            <label asp-for="TrangThai" class="form-label-luxury mb-2">Trạng thái phòng <span class="text-danger">*</span></label>
                            <div class="d-flex gap-2">
                                <input type="radio" asp-for="TrangThai" value="Còn trống" class="btn-check" id="status-empty" required>
                                <label class="btn btn-status btn-status-green flex-fill" for="status-empty">
                                    <i class="bi bi-check-circle-fill mb-1 d-block" style="font-size: 1.2rem;"></i>
                                    Còn trống
                                </label>

                                <input type="radio" asp-for="TrangThai" value="Đã đặt" class="btn-check" id="status-booked">
                                <label class="btn btn-status btn-status-red flex-fill" for="status-booked">
                                    <i class="bi bi-door-closed-fill mb-1 d-block" style="font-size: 1.2rem;"></i>
                                    Đã đặt
                                </label>

                                <input type="radio" asp-for="TrangThai" value="Bảo trì" class="btn-check" id="status-maintenance">
                                <label class="btn btn-status btn-status-yellow flex-fill" for="status-maintenance">
                                    <i class="bi bi-tools mb-1 d-block" style="font-size: 1.2rem;"></i>
                                    Bảo trì
                                </label>
                            </div>
                            <span asp-validation-for="TrangThai" class="text-danger small fw-bold mt-2 d-block"></span>
                        </div>

                        <div class="col-12">
                            <label asp-for="MoTa" class="form-label-luxury">Mô tả chi tiết <span class="text-muted fw-normal">(Không bắt buộc)</span></label>
                            <div class="input-group luxury-input-group">
                                <span class="input-group-text"><i class="bi bi-card-text"></i></span>
                                <textarea asp-for="MoTa" class="form-control" rows="4" placeholder="Nhập mô tả về tiện nghi, không gian, view của phòng..."></textarea>
                            </div>
                            <span asp-validation-for="MoTa" class="text-danger small fw-bold"></span>
                        </div>

                    </div>
                </div>

                <div class="col-12">
                    <h5 class="section-header"><i class="bi bi-images me-2"></i>Thư viện Hình ảnh</h5>

                    <input type="hidden" name="ExistingImages" id="existingImagesInput" value="@Model?.HinhAnh" />

                    <div class="row g-4">
                        <div class="col-md-4 col-lg-3">
                            <div class="upload-zone-container h-100">
                                <input type="file" name="HinhAnhFiles" id="fileInput" multiple accept="image/*" class="visually-hidden" onchange="handleFileSelect(event)">
                                <label for="fileInput" class="upload-label-luxury d-flex flex-column justify-content-center align-items-center text-center h-100 p-4" style="min-height: 250px; cursor: pointer;">
                                    <i class="bi bi-cloud-arrow-up-fill upload-icon mb-3" style="font-size: 3.5rem;"></i>
                                    <span class="upload-text d-block fs-5 fw-bold text-white">Bấm để tải thêm ảnh</span>
                                    <span class="upload-hint small text-muted mt-2">(Ảnh mới & Ảnh cũ)</span>
                                </label>
                            </div>
                        </div>

                        <div class="col-md-8 col-lg-9">
                            <div id="imageThumbnailsContainer"
                                 class="thumbnail-container thumbnail-horizontal thin-scrollbar border border-secondary border-opacity-25 rounded p-3"
                                 style="height: 340px; overflow-x: auto; overflow-y: hidden; background: rgba(0,0,0,0.1);">

                                @{
                                    if (!string.IsNullOrEmpty(Model?.HinhAnh))
                                    {
                                        var currentImages = Model.HinhAnh.Split(';');
                                        foreach (var img in currentImages)
                                        {
                                            if (!string.IsNullOrEmpty(img))
                                            {
                                                <div class="thumbnail-wrapper existing-image-item" data-path="@img">
                                                    <button type="button" class="btn-delete-image" onclick="removeExistingImage(this, '@img')">
                                                        <i class="bi bi-x"></i>
                                                    </button>
                                                    <img src="@img" class="thumbnail-img" />
                                                </div>
                                            }
                                        }
                                    }
                                    else
                                    {
                                        <p id="noImageText" class="text-muted small fst-italic text-center w-100 m-0" style="margin-top: 150px !important;">
                                            <i class="bi bi-camera me-1"></i> Chưa có hình ảnh nào.
                                        </p>
                                    }
                                }
                            </div>
                        </div>
                    </div>
                </div>

            </div>

            <div class="form-actions mt-5 pt-4 border-top border-secondary border-opacity-25 text-end">
                <a class="btn btn-back-luxury" asp-action="Index" asp-route-id="@Model.MaKhachSan">
                    <i class="bi bi-arrow-left me-2"></i>Hủy bỏ
                </a>
                <button type="submit" class="btn btn-create-luxury">
                    <i class="bi bi-pencil-square me-2"></i> Lưu thay đổi
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="~/js/Share/Success.js"></script>

    <script>
        // --- 1. ĐỒNG BỘ GIÁ PHÒNG ---
        const display = document.getElementById("GiaPhongDisplay");
        const hidden = document.getElementById("GiaPhong");

        function syncGiaPhong() {
            let raw = display.value.replace(/\./g, "").replace(/,/g, "").trim();
            hidden.value = raw || 0;
            if (raw) {
                display.value = new Intl.NumberFormat('vi-VN').format(raw);
            }
        }

        display.addEventListener("blur", syncGiaPhong);
        display.addEventListener("input", function() {
            let raw = this.value.replace(/\./g, "").replace(/,/g, "").trim();
            hidden.value = raw || 0;
        });

        // --- 2. QUẢN LÝ ẢNH ---
        const dt = new DataTransfer();
        const existingImagesInput = document.getElementById("existingImagesInput");

        // Xóa ảnh cũ
        function removeExistingImage(btn, path) {
            btn.parentElement.remove();
            let currentPaths = existingImagesInput.value.split(';');
            let updatedPaths = currentPaths.filter(p => p !== path && p !== "");
            existingImagesInput.value = updatedPaths.join(';');
            checkEmptyContainer();
        }

        // Thêm ảnh mới
        function handleFileSelect(event) {
            const files = event.target.files;
            const container = document.getElementById("imageThumbnailsContainer");
            const noImageText = document.getElementById("noImageText");

            if (files.length > 0 && noImageText) noImageText.remove(); // Xóa luôn thẻ text nếu có

            Array.from(files).forEach(file => {
                if (!file.type.startsWith('image/')) return;

                dt.items.add(file);
                const reader = new FileReader();
                reader.onload = function(e) {
                    createNewThumbnail(e.target.result, container, file);
                };
                reader.readAsDataURL(file);
            });
            document.getElementById('fileInput').files = dt.files;
        }

        function createNewThumbnail(src, container, fileObj) {
            const imgWrapper = document.createElement("div");
            imgWrapper.className = "thumbnail-wrapper fade-in-up";

            const deleteBtn = document.createElement("button");
            deleteBtn.className = "btn-delete-image";
            deleteBtn.innerHTML = '<i class="bi bi-x"></i>';
            deleteBtn.type = "button";

            deleteBtn.onclick = function () {
                removeNewFile(fileObj, imgWrapper);
            };

            const img = document.createElement("img");
            img.src = src;
            img.className = "thumbnail-img";

            imgWrapper.appendChild(deleteBtn);
            imgWrapper.appendChild(img);
            container.appendChild(imgWrapper);
        }

        function removeNewFile(fileToRemove, element) {
            const newDt = new DataTransfer();
            const currentFiles = dt.files;
            for (let i = 0; i < currentFiles.length; i++) {
                if (currentFiles[i] !== fileToRemove) {
                    newDt.items.add(currentFiles[i]);
                }
            }
            dt.items.clear();
            for (let i = 0; i < newDt.files.length; i++) {
                dt.items.add(newDt.files[i]);
            }
            document.getElementById('fileInput').files = dt.files;
            element.remove();
            checkEmptyContainer();
        }

        function checkEmptyContainer() {
            const container = document.getElementById("imageThumbnailsContainer");
            if (container.querySelectorAll('.thumbnail-wrapper').length === 0) {
                container.innerHTML = `<p id="noImageText" class="text-muted small fst-italic text-center w-100 m-0" style="margin-top: 150px !important;">
                    <i class="bi bi-camera me-1"></i> Chưa có hình ảnh nào.
                </p>`;
            }
        }

        // --- 3. GỬI FORM BẰNG AJAX ---
        document.getElementById("editForm").addEventListener("submit", async function (e) {
            e.preventDefault();
            syncGiaPhong(); // Đồng bộ giá trước khi gửi

            const form = this;
            const formData = new FormData(form);
            const submitBtn = form.querySelector('button[type="submit"]');

            const originalBtnText = submitBtn.innerHTML;
            submitBtn.innerHTML = '<i class="bi bi-hourglass-split me-2"></i>Đang lưu...';
            submitBtn.disabled = true;

            try {
                const response = await fetch(form.action, {
                    method: 'POST',
                    body: formData
                });

                const result = await response.json();

                if (result.success) {
                    window.location.href = result.redirectUrl;
                } else {
                    Swal.fire({
                        icon: 'error',
                        title: 'Thông tin chưa hợp lệ',
                        text: result.message,
                        background: '#1e1e1e',
                        color: '#fff',
                        confirmButtonColor: '#ffc107'
                    });
                    submitBtn.innerHTML = originalBtnText;
                    submitBtn.disabled = false;
                }
            } catch (error) {
                Swal.fire({
                    icon: 'error',
                    title: 'Lỗi',
                    text: 'Lỗi kết nối máy chủ',
                    background: '#1e1e1e',
                    color: '#fff',
                    confirmButtonColor: '#ffc107'
                });
                submitBtn.innerHTML = originalBtnText;
                submitBtn.disabled = false;
            }
        });
    </script>
}