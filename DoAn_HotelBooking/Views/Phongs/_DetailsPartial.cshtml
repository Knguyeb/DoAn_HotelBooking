@using System.Globalization
@model DoAn_HotelBooking.Models.Phong

@{
    var quyen = Context.Session.GetString("QuyenHan");
    string trangThai = Model.TrangThaiHomNay ?? Model.TrangThai;

    string badgeDanhGia = "";
    if (ViewBag.TrungBinhSao > 0)
    {
        badgeDanhGia = $"<span class='badge bg-warning text-dark shadow-sm ms-3 d-inline-flex align-items-center gap-1' style='font-size: 0.85rem; padding: 5px 10px; border-radius: 6px;'><i class='fas fa-star text-danger'></i> <span class='fw-bold'>{ViewBag.TrungBinhSao.ToString("0.0")}</span></span> <span class='ms-2 text-muted fw-normal' style='font-size: 0.85rem;'>({ViewBag.SoDanhGia} đánh giá)</span>";
    }
    else
    {
        badgeDanhGia = "<span class='badge text-light shadow-sm ms-3 fw-normal d-inline-flex align-items-center' style='font-size: 0.8rem; padding: 5px 10px; border-radius: 6px; background-color: rgba(255,255,255,0.1); border: 1px solid rgba(255,255,255,0.2);'>Chưa có đánh giá</span>";
    }
}

<div id="hidden-modal-title" class="d-none">
    <div class="d-flex align-items-center justify-content-between w-100" style="color: #ffc107;">
        <div class="d-flex align-items-center">
            <i class="fas fa-bed me-2"></i> Phòng @Model.SoPhong
            @Html.Raw(badgeDanhGia)
        </div>
        <button type="button" class="btn btn-sm btn-outline-light rounded-pill px-3 ms-3" onclick="toggleRoomView(@Model.ID, this)" style="font-size: 0.85rem; font-weight: 500;">
            <i class="fas fa-comments me-1"></i> Xem bình luận
        </button>
    </div>
</div>

<link href="~/css/KhachSan/Details.css" rel="stylesheet" />

<style>
    .custom-scrollbar::-webkit-scrollbar {
        width: 6px;
    }

    .custom-scrollbar::-webkit-scrollbar-track {
        background: rgba(255, 255, 255, 0.02);
        border-radius: 8px;
    }

    .custom-scrollbar::-webkit-scrollbar-thumb {
        background: rgba(255, 193, 7, 0.5);
        border-radius: 8px;
    }

        .custom-scrollbar::-webkit-scrollbar-thumb:hover {
            background: rgba(255, 193, 7, 0.9);
        }

    .fade-in-tab {
        animation: fadeInTab 0.3s ease-in-out forwards;
    }

    @@keyframes fadeInTab {
        from {
            opacity: 0;
            transform: translateY(5px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }
</style>

<div id="viewChiTiet_@Model.ID" class="fade-in-tab">
    <div class="row g-4 align-items-stretch">
        <div class="col-md-6 d-flex">
            @if (!string.IsNullOrEmpty(Model.HinhAnh))
            {
                var anhList = Model.HinhAnh.Split(";", StringSplitOptions.RemoveEmptyEntries);
                <div id="roomPopupCarousel" class="carousel slide shadow-sm rounded overflow-hidden flex-fill" data-bs-ride="carousel" data-bs-interval="3000">
                    <div class="carousel-indicators">
                        @for (int i = 0; i < anhList.Length; i++)
                        {
                            <button type="button" data-bs-target="#roomPopupCarousel" data-bs-slide-to="@i" class="@(i == 0 ? "active" : "")"></button>
                        }
                    </div>
                    <div class="carousel-inner h-100">
                        @for (int i = 0; i < anhList.Length; i++)
                        {
                            <div class="carousel-item h-100 @(i == 0 ? "active" : "")">
                                <img src="@anhList[i]" alt="Ảnh phòng @Model.SoPhong" class="d-block w-100 h-100" style="object-fit: cover; min-height: 300px;" />
                            </div>
                        }
                    </div>
                    <button class="carousel-control-prev" type="button" data-bs-target="#roomPopupCarousel" data-bs-slide="prev">
                        <span class="carousel-control-prev-icon" aria-hidden="true"></span>
                    </button>
                    <button class="carousel-control-next" type="button" data-bs-target="#roomPopupCarousel" data-bs-slide="next">
                        <span class="carousel-control-next-icon" aria-hidden="true"></span>
                    </button>
                </div>
            }
            else
            {
                <div class="d-flex align-items-center justify-content-center rounded flex-fill" style="background: rgba(0,0,0,0.2); min-height: 300px;">
                    <p class="text-muted">Chưa có hình ảnh</p>
                </div>
            }
        </div>

        <div class="col-md-6 d-flex flex-column">
            <div class="p-3 p-lg-4 rounded-3 d-flex flex-column flex-grow-1" style="border: 1px solid rgba(255, 255, 255, 0.1); background: rgba(0, 0, 0, 0.15);">
                <dl class="row mb-0" style="font-size: 0.95rem;">
                    <dt class="col-sm-5 text-muted fw-normal mb-3 d-flex align-items-center"><i class="fas fa-layer-group fa-fw me-2"></i>Tầng</dt>
                    <dd class="col-sm-7 text-light fw-bold mb-3 d-flex align-items-center">@Model.Tang</dd>

                    <dt class="col-sm-5 text-muted fw-normal mb-3 d-flex align-items-center"><i class="fas fa-tags fa-fw me-2"></i>Loại phòng</dt>
                    <dd class="col-sm-7 text-light fw-bold mb-3 d-flex align-items-center">@Model.LoaiPhong</dd>

                    <dt class="col-sm-5 text-muted fw-normal mb-3 d-flex align-items-center"><i class="fas fa-user-friends fa-fw me-2"></i>Sức chứa</dt>
                    <dd class="col-sm-7 text-light fw-bold mb-3 d-flex align-items-center">@Model.SucChua người</dd>

                    <dt class="col-sm-5 text-muted fw-normal mb-0 d-flex align-items-center"><i class="fas fa-info-circle fa-fw me-2"></i>Trạng thái</dt>
                    <dd class="col-sm-7 mb-0 d-flex align-items-center">
                        @if (trangThai == "Còn trống")
                        {
                            <span class="badge d-inline-flex align-items-center" style="background-color: rgba(40, 167, 69, 0.15); color: #28a745; border: 1px solid rgba(40,167,69,0.5); padding: 5px 12px; font-size: 0.85rem; border-radius: 6px;">
                                <i class="bi bi-check-circle-fill me-2"></i> Còn trống
                            </span>
                        }
                        else if (trangThai == "Đã đặt hôm nay")
                        {
                            <span class="badge d-inline-flex align-items-center" style="background-color: rgba(253, 126, 20, 0.15); color: #fd7e14; border: 1px solid rgba(253,126,20,0.5); padding: 5px 12px; font-size: 0.85rem; border-radius: 6px;">
                                <i class="bi bi-calendar-check-fill me-2"></i> Đã đặt hôm nay
                            </span>
                        }
                        else if (trangThai == "Đang sử dụng")
                        {
                            <span class="badge d-inline-flex align-items-center" style="background-color: rgba(220, 53, 69, 0.15); color: #dc3545; border: 1px solid rgba(220,53,69,0.5); padding: 5px 12px; font-size: 0.85rem; border-radius: 6px;">
                                <i class="bi bi-door-closed-fill me-2"></i> Đang sử dụng
                            </span>
                        }
                        else if (trangThai == "Bảo trì")
                        {
                            <span class="badge d-inline-flex align-items-center" style="background-color: rgba(255, 193, 7, 0.15); color: #ffc107; border: 1px solid rgba(255,193,7,0.5); padding: 5px 12px; font-size: 0.85rem; border-radius: 6px;">
                                <i class="bi bi-tools me-2"></i> Bảo trì
                            </span>
                        }
                    </dd>
                </dl>

                <div class="d-flex align-items-center mt-4">
                    <span class="text-muted fw-normal me-2" style="font-size: 0.95rem;">
                        <i class="fas fa-money-bill-wave fa-fw me-1"></i>Giá:
                    </span>
                    <div class="dropup d-inline-block">
                        <span class="text-success fs-4 fw-bold dropdown-toggle" data-bs-toggle="dropdown" aria-expanded="false" data-base-price="@Model.GiaPhong" style="cursor: pointer;">
                            @Convert.ToDouble(Model.GiaPhong).ToString("N0") VNĐ
                        </span>
                        <ul class="dropdown-menu dropdown-menu-dark shadow-lg mb-2" style="border: 1px solid rgba(255,255,255,0.1); border-radius: 12px;">
                            <li><a class="dropdown-item currency-option" href="javascript:void(0)" data-currency="VND">🇻🇳 VNĐ</a></li>
                            <li><a class="dropdown-item currency-option" href="javascript:void(0)" data-currency="USD">🇺🇸 USD</a></li>
                            <li><a class="dropdown-item currency-option" href="javascript:void(0)" data-currency="EUR">🇪🇺 EUR</a></li>
                        </ul>
                    </div>
                    <span class="text-muted fs-6 fw-bold ms-2">/ đêm</span>
                </div>
            </div>

            <div class="mt-3">
                @if (quyen == "Khách hàng")
                {
                    @if (trangThai == "Bảo trì")
                    {
                        <button type="button" class="btn btnDisabled w-100 text-center py-2 fw-bold d-flex align-items-center justify-content-center"
                                onclick="Swal.fire({ icon: 'info', title: 'Đang bảo trì!', text: 'Phòng này đang được dọn dẹp hoặc sửa chữa.', confirmButtonText: 'Đóng', background: '#1e1e1e', color: '#ffffff', confirmButtonColor: '#ffc107' })">
                            <i class="bi bi-tools me-2"></i> Đang bảo trì
                        </button>
                    }
                    else
                    {
                        <a asp-controller="DatPhongs" asp-action="Create" asp-route-MaPhong="@Model.ID" asp-route-MaTaiKhoan="@ViewBag.MaTaiKhoan" class="btn btnSua w-100 text-center py-2 fw-bold d-flex align-items-center justify-content-center">
                            <i class="bi bi-calendar-check-fill me-2"></i> Đặt phòng ngay
                        </a>
                    }
                }
                else
                {
                    <div class="w-100 rounded p-2" style="background: rgba(255,255,255,0.05); border: 1px dashed rgba(255,255,255,0.2);">
                        <p class="text-muted w-100 text-center m-0 fst-italic" style="font-size: 0.9rem;">
                            Vui lòng đăng nhập tài khoản khách hàng để đặt phòng.
                        </p>
                    </div>
                }
            </div>
        </div>
    </div>

    <!-- PHẦN MÔ TẢ PHÒNG ĐÃ THÊM THANH CUỘN ĐỘC LẬP -->
    @if (!string.IsNullOrEmpty(Model.MoTa))
    {
        <div class="mt-4 p-3 p-lg-4 rounded-3" style="border: 1px solid rgba(255, 255, 255, 0.1); background: rgba(0, 0, 0, 0.15);">
            <h6 class="text-warning mb-3 fw-bold"><i class="fas fa-align-left me-2"></i>Mô tả chi tiết</h6>
            <div class="custom-scrollbar pe-2" style="max-height: 150px; overflow-y: auto;">
                <p class="text-light mb-0">
                    @Model.MoTa
                </p>
            </div>
        </div>
    }
</div>

<div id="viewBinhLuan_@Model.ID" style="display: none;" class="fade-in-tab pt-2">
    <div id="areaDanhSachBinhLuan_@Model.ID" class="custom-scrollbar pe-2" style="max-height: 380px; overflow-y: auto;">
        <div class="text-center text-muted py-5">
            <div class="spinner-border spinner-border-sm text-warning me-2" role="status"></div>
            Đang tải các bình luận...
        </div>
    </div>
</div>