@using System.Globalization
@model IEnumerable<DoAn_HotelBooking.Models.Phong>

@{
    ViewData["Title"] = "Danh sách phòng";
}

@inject IHttpContextAccessor HttpContextAccessor
@{
    var quyenHan = HttpContextAccessor.HttpContext.Session.GetString("QuyenHan");
}

<link rel="stylesheet" href="~/css/KhachSan/Index.css" asp-append-version="true" />
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">

<div class="container-fluid fade-in-up mt-4">
    @Html.AntiForgeryToken()

    <!-- ================= THỐNG KÊ & TIÊU ĐỀ ================= -->
    <div class="row mb-4 g-3 align-items-stretch">
        <div class="col-md-4">
            <div class="stat-card h-100 d-flex align-items-center">
                <div class="stat-icon" style="background: linear-gradient(135deg, #FFD700, #FF4500);">
                    <i class="bi bi-door-open-fill"></i>
                </div>
                <div class="stat-info">
                    <h6>Tổng Số Phòng</h6>
                    <h3 id="totalCount">@Model.Count()</h3>
                </div>
            </div>
        </div>

        <div class="col-md-8">
            <div class="stat-card h-100 d-flex align-items-center justify-content-between">
                <div>
                    <h2 class="page-title mb-1">DANH SÁCH PHÒNG</h2>
                    <p class="text-secondary mb-0 small">
                        <i class="bi bi-building me-1"></i> Khách sạn: <strong class="text-light">@ViewBag.KhachSan.TenKhachSan</strong>
                    </p>
                </div>
                <div class="d-flex gap-2">
                    @if (quyenHan != "Nhân viên")
                    {
                        <a asp-action="Create" asp-route-id="@ViewBag.MaKhachSan" class="btn btn-primary-luxury text-decoration-none">
                            <i class="bi bi-plus-lg me-1"></i> Thêm phòng
                        </a>
                    }
                    <a asp-action="ExportExcel" asp-route-maKhachSan="@ViewBag.MaKhachSan" class="btn btn-excel-luxury text-decoration-none">
                        <i class="bi bi-file-earmark-excel me-1"></i> Xuất Excel
                    </a>
                </div>
            </div>
        </div>
    </div>

    <!-- ================= KHU VỰC BẢNG DỮ LIỆU ================= -->
    <div class="glass-container">
        <!-- Thanh công cụ -->
        <div class="toolbar-wrapper mb-3">
            <div class="search-box-luxury">
                <i class="bi bi-search"></i>
                <input type="text" id="searchRoom" placeholder="Tìm kiếm số phòng, loại phòng, trạng thái..." autocomplete="off">
            </div>
        </div>

        <!-- Bảng -->
        <div class="table-responsive">
            <table class="table custom-table align-middle" id="roomTable">
                <thead>
                    <tr>
                        <th class="text-center" style="width: 5%">#</th>
                        <th class="text-center">Số phòng</th>
                        <th class="text-center">Tầng</th>
                        <th class="text-center">Loại phòng</th>
                        <th class="text-center">Sức chứa</th>
                        <th class="text-center">Giá (VNĐ)</th>
                        <th class="text-center">Trạng thái</th>
                        <th class="text-center">Tác vụ</th>
                    </tr>
                </thead>
                <tbody>
                    @{
                        int i = 1;
                    }
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="text-center text-muted fw-bold">@i</td>
                            <td class="text-center fw-bold" style="color: var(--yellow); font-size: 1.1rem;">
                                <i class="bi bi-door-closed me-1"></i> @item.SoPhong
                            </td>
                            <td class="text-center">
                                Tầng @item.Tang
                            </td>
                            <td class="text-center">
                                @item.LoaiPhong
                            </td>
                            <td class="text-center">
                                <i class="bi bi-people-fill text-info me-1"></i> @item.SucChua
                            </td>
                            <td class="text-center text-success fw-bold">
                                @item.GiaPhong.ToString("N0", new CultureInfo("vi-VN"))
                            </td>
                            <td class="text-center align-middle">
                                @{
                                    string trangThai = item.TrangThai ?? "";
                                    string badgeClass = "";
                                    string badgeIcon = "";
                                    string customStyle = "";

                                    if (trangThai == "Còn trống")
                                    {
                                        badgeClass = "text-success";
                                        badgeIcon = "bi-check-circle-fill";
                                        customStyle = "background-color: rgba(40, 167, 69, 0.15); border: 1px solid rgba(40, 167, 69, 0.5);";
                                    }
                                    else if (trangThai == "Đã đặt")
                                    {
                                        badgeClass = "text-danger";
                                        badgeIcon = "bi-door-closed-fill";
                                        customStyle = "background-color: rgba(220, 53, 69, 0.15); border: 1px solid rgba(220, 53, 69, 0.5);";
                                    }
                                    else if (trangThai == "Bảo trì")
                                    {
                                        badgeClass = "text-warning";
                                        badgeIcon = "bi-tools";
                                        customStyle = "background-color: rgba(255, 193, 7, 0.15); border: 1px solid rgba(255, 193, 7, 0.5);";
                                    }
                                    else
                                    {
                                        badgeClass = "text-secondary";
                                        badgeIcon = "bi-info-circle-fill";
                                        customStyle = "background-color: rgba(108, 117, 125, 0.15); border: 1px solid rgba(108, 117, 125, 0.5);";
                                    }
                                }

                                <span class="badge @badgeClass d-inline-flex align-items-center gap-1 shadow-sm"
                                      style="@customStyle padding: 6px 12px; font-size: 0.85rem; border-radius: 8px; font-weight: 600;">
                                    <i class="bi @badgeIcon"></i> @trangThai
                                </span>
                            </td>
                            <td>
                                <!-- Bộ nút tác vụ Icon -->
                                <div class="d-flex justify-content-center gap-2">
                                    <button type="button"
                                            class="btn btn-icon-luxury btn-ai-glow show-ai-summary"
                                            data-url="@Url.Action("TongHopReview", "AI", new { maPhong = item.ID })"
                                            title="Phân tích đánh giá bằng AI">
                                        <i class="bi bi-robot"></i>
                                    </button>

                                    <a asp-action="Edit" asp-route-id="@item.ID" class="btn btn-icon-luxury btn-warning-glow" title="Sửa thông tin">
                                        <i class="bi bi-pencil-square"></i>
                                    </a>

                                    <button type="button"
                                            class="btn btn-icon-luxury btn-info-glow"
                                            data-bs-toggle="modal"
                                            data-bs-target="#roomDetailModal"
                                            data-id="@item.ID"
                                            data-tenphong="Phòng @item.SoPhong"
                                            data-url="@Url.Action("DetailsPartial", "Phongs", new { id = item.ID })">
                                        <i class="bi bi-info-circle"></i>
                                    </button>

                                    @if (quyenHan != "Nhân viên")
                                    {
                                        <button class="btn btn-icon-luxury btn-danger-glow" onclick="confirmDelete('@item.ID')" title="Xóa phòng">
                                            <i class="bi bi-trash-fill"></i>
                                        </button>
                                    }
                                </div>

                                <form id="deleteForm-@item.ID" method="post" asp-action="Delete" asp-route-id="@item.ID" style="display:none;">
                                    @Html.AntiForgeryToken()
                                </form>
                            </td>
                        </tr>
                        i++;
                    }
                </tbody>
            </table>

            <!-- Hiển thị khi không có kết quả -->
            <div id="noResults" class="text-center py-5" style="display: none;">
                <div class="mb-3">
                    <i class="bi bi-search" style="font-size: 3rem; color: var(--yellow); opacity: 0.5;"></i>
                </div>
                <h5 class="text-light">Không tìm thấy phòng nào</h5>
                <p class="text-secondary">Vui lòng thử lại với từ khóa khác.</p>
                <!-- SỬA onclick TẠI ĐÂY -->
                <button type="button" onclick="pageConfig.clearSearch()" class="btn btn-outline-warning mt-2 rounded-pill px-4">
                    <i class="bi bi-arrow-clockwise me-1"></i> Hiển thị tất cả
                </button>
            </div>
        </div>

        <!-- Footer Bảng & Phân trang -->
        <div class="table-footer d-flex justify-content-between align-items-center mt-3">
            <span class="text-secondary small">Đang hiển thị <strong id="visibleCount" class="text-light">0</strong> phòng</span>
            <nav>
                <ul id="pagination" class="pagination pagination-luxury mb-0">
                    <!-- Nút phân trang sẽ được render bằng JS -->
                </ul>
            </nav>
        </div>
    </div>
</div>

<!-- Modal Chi tiết phòng -->
<div class="modal fade" id="roomDetailModal" tabindex="-1" aria-labelledby="roomDetailModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered modal-dialog-scrollable">
        <div class="modal-content custom-modal-bg text-light" style="border: 1px solid rgba(255, 215, 0, 0.2); border-radius: 15px;">
            <div class="modal-header border-bottom-0 pb-0">
                <h5 class="modal-title text-warning fw-bold" id="roomDetailModalLabel">
                    Đang tải...
                </h5>
                <button type="button" class="btn-close btn-close-white opacity-75" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>

            <div class="modal-body pt-3 pb-4" id="roomDetailModalBody">
                <!-- Vùng chứa dữ liệu AJAX -->
            </div>
        </div>
    </div>
</div>

<div class="offcanvas offcanvas-end custom-modal-bg text-light" tabindex="-1" id="aiSummaryOffcanvas" style="width: 400px; border-left: 1px solid rgba(181, 51, 214, 0.4); background: rgba(20, 20, 20, 0.95); backdrop-filter: blur(10px);">
    <div class="offcanvas-header" style="border-bottom: 1px solid rgba(255,255,255,0.1);">
        <h5 class="offcanvas-title fw-bold" style="color: #b533d6;">
            <i class="bi bi-robot me-2"></i> Trợ Lý AI
        </h5>
        <button type="button" class="btn-close btn-close-white opacity-75" data-bs-dismiss="offcanvas"></button>
    </div>
    <div class="offcanvas-body" id="aiSummaryOffcanvasBody">
    </div>
</div>

@section Scripts {
    <input type="hidden" id="successMessage" value="@TempData["SuccessMessage"]" />
    <input type="hidden" id="errorMessage" value="@TempData["ErrorMessage"]" />

    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="~/js/Share/Delete.js" asp-append-version="true"></script>
    <script src="~/js/Share/Success.js" asp-append-version="true"></script>
    <script src="~/js/Share/DoiTien.js"></script>
    <script src="~/js/Share/PopUpDetails.js"></script>
    <script src="~/js/Share/phantrang.js" asp-append-version="true"></script>

    <script>
        var pageConfig;

        document.addEventListener("DOMContentLoaded", function () {
            // Khởi tạo tính năng tìm kiếm, phân trang
            pageConfig = new TablePaginator({
                tableId: 'roomTable',
                searchInputId: 'searchRoom',
                paginationId: 'pagination',
                visibleCountId: 'visibleCount',
                noResultsId: 'noResults',
                rowsPerPage: 10 // Đặt số lượng dòng hiển thị trên 1 trang
            });
        });

        document.body.addEventListener('click', function (e) {
            // Tìm xem user có bấm vào nút có class 'show-ai-summary' hoặc icon bên trong nó không
            const aiButton = e.target.closest('.show-ai-summary');

            if (aiButton) {
                e.preventDefault(); // Chặn hành vi mặc định

                const url = aiButton.getAttribute('data-url');
                const offcanvasBody = document.getElementById('aiSummaryOffcanvasBody');

                // 1. Reset giao diện về trạng thái Loading
                offcanvasBody.innerHTML = `
                    <div class="text-center py-5">
                        <div class="spinner-grow" style="color: #b533d6; width: 3rem; height: 3rem;" role="status"></div>
                        <p class="mt-4 text-secondary">AI đang đọc và tổng hợp bình luận...</p>
                    </div>`;

                // 2. Mở Offcanvas
                const aiOffcanvasElement = document.getElementById('aiSummaryOffcanvas');
                const aiOffcanvas = bootstrap.Offcanvas.getInstance(aiOffcanvasElement) || new bootstrap.Offcanvas(aiOffcanvasElement);
                aiOffcanvas.show();

                // 3. Gọi dữ liệu ngầm (AJAX)
                fetch(url)
                    .then(response => response.text())
                    .then(html => {
                        offcanvasBody.innerHTML = html;
                    })
                    .catch(error => {
                        offcanvasBody.innerHTML = `
                            <div class="text-center text-danger py-5">
                                <i class="bi bi-exclamation-triangle fs-1"></i>
                                <p class="mt-3">Lỗi kết nối đến AI. Vui lòng thử lại sau.</p>
                            </div>`;
                    });
            }
        });
    </script>

    <script>
        function toggleRoomView(maPhong, btnElement) {
            var $viewChiTiet = $('#viewChiTiet_' + maPhong);
            var $viewBinhLuan = $('#viewBinhLuan_' + maPhong);
            var $btn = $(btnElement);

            if ($viewChiTiet.is(':visible')) {
                $viewChiTiet.hide();
                $viewBinhLuan.show();
                $btn.html('<i class="fas fa-info-circle me-1"></i> Chi tiết phòng');

                if (!$viewBinhLuan.data('loaded')) {
                    loadCommentsData(maPhong);
                }
            } else {
                $viewBinhLuan.hide();
                $viewChiTiet.show();
                $btn.html('<i class="fas fa-comments me-1"></i> Xem bình luận');
            }
        }

        // Hàm gọi dữ liệu Bình luận
        function loadCommentsData(maPhong) {
            var area = $('#areaDanhSachBinhLuan_' + maPhong);
            $('#viewBinhLuan_' + maPhong).data('loaded', true);

            $.ajax({
                url: '/DanhGiaPhongs/GetBinhLuanByPhong',
                type: 'GET',
                data: { maPhong: maPhong },
                success: function (res) {
                    area.empty();
                    if (res.success === false) {
                        area.append('<div class="alert alert-danger text-center"><i class="fas fa-bug me-2"></i>Lỗi Backend: ' + res.errorMessage + '</div>');
                        return;
                    }

                    if (res.data && res.data.length > 0) {
                        res.data.forEach(function(item) {
                            area.append(`
                                <div style="border-bottom: 1px solid rgba(255,255,255,0.1); padding: 15px 0;">
                                    <div class="d-flex justify-content-between">
                                        <strong class="text-info"><i class="fas fa-user-circle me-2"></i> ${item.tenKhachHang}</strong>
                                        <span class="text-muted" style="font-size: 0.8rem;"><i class="far fa-clock me-1"></i> ${item.ngayTao}</span>
                                    </div>
                                    <p class="text-light mt-2 mb-0 ps-4" style="border-left: 2px solid #ffc107;">${item.noiDung}</p>
                                </div>
                            `);
                        });
                    } else {
                        area.append(`
                            <div class="text-center text-muted py-5 fst-italic" style="background: rgba(255,255,255,0.02); border-radius: 8px;">
                                <i class="fas fa-comment-slash fa-2x mb-3 d-block opacity-50"></i>
                                Chưa có bình luận nào cho phòng này.
                            </div>
                        `);
                    }
                },
                error: function () {
                    area.html('<div class="text-danger text-center py-4"><i class="fas fa-exclamation-circle me-1"></i> Lỗi kết nối API! Vui lòng kiểm tra lại đường dẫn.</div>');
                }
            });
        }
    </script>
}