@model IEnumerable<DoAn_HotelBooking.Models.DatPhong>

@{
    ViewData["Title"] = "Lịch sử đặt phòng";

    // --- TÍNH TOÁN THỐNG KÊ ---
    int totalCards = Model.Count();
    decimal totalPaid = 0;
    int totalPoints = 0; // Thêm biến tính tổng điểm

    @foreach (var item in Model)
    {
        // Chỉ tính tiền và điểm cho các đơn đã thanh toán
        if (item.TrangThaiThanhToan == "Đã thanh toán")
        {
            int soNgay = (item.NgayTraPhong - item.NgayNhanPhong).Days;
            if (soNgay <= 0) soNgay = 1;

            decimal tien = (item.Phong?.GiaPhong ?? 0) * soNgay;
            totalPaid += tien;
            totalPoints += (int)(tien / 100000); // Cộng dồn điểm
        }
    }

    // Khởi tạo mặc định
    string colorHex = "#f8f9fa";
    string glowClass = "";
    string iconClass = "bi-star-fill";
    string tenHang = ViewBag.TenHang as string ?? "";

    if (tenHang.Contains("Đồng", StringComparison.OrdinalIgnoreCase))
    {
        colorHex = "#CD7F32";
        glowClass = "glow-dong";
        iconClass = "bi-award-fill";
    }
    else if (tenHang.Contains("Bạc", StringComparison.OrdinalIgnoreCase))
    {
        colorHex = "#C0C0C0";
        glowClass = "glow-bac";
        iconClass = "bi-award-fill";
    }
    else if (tenHang.Contains("Vàng", StringComparison.OrdinalIgnoreCase))
    {
        colorHex = "#FFD700";
        glowClass = "glow-vang";
        iconClass = "bi-award-fill";
    }
    else if (tenHang.Contains("Bạch kim", StringComparison.OrdinalIgnoreCase) || tenHang.Contains("Platinum", StringComparison.OrdinalIgnoreCase))
    {
        colorHex = "#00CFFF";
        glowClass = "glow-bachkim";
        iconClass = "bi-gem";
    }
    else if (tenHang.Contains("Kim cương", StringComparison.OrdinalIgnoreCase) || tenHang.Contains("Diamond", StringComparison.OrdinalIgnoreCase))
    {
        colorHex = "transparent"; // Màu kim cương được CSS gradient lo
        glowClass = "glow-kimcuong";
        iconClass = "bi-gem";
    }
}

<link rel="stylesheet" href="~/css/KhachSan/Index.css" asp-append-version="true" />
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">

<style>
    /* Hiệu ứng dịch chuyển khung nền liên tục từ trái qua phải dùng chung */
    @@keyframes flowLeftToRight {
        0% {
            background-position: 100% 0;
        }

        100% {
            background-position: 0% 0;
        }
    }

    /* 🥉 Hạng Đồng (#CD7F32) */
    .glow-dong {
        box-shadow: 0 0 6px rgba(205, 127, 50, 0.5) !important;
        background-image: linear-gradient(to right, rgba(205, 127, 50, 0.1), rgba(205, 127, 50, 0.4), rgba(205, 127, 50, 0.1), rgba(205, 127, 50, 0.4)) !important;
        background-size: 300% 100% !important;
        animation: flowLeftToRight 3s linear infinite !important;
    }

    /* 🥈 Hạng Bạc (#C0C0C0) */
    .glow-bac {
        box-shadow: 0 0 10px rgba(192, 192, 192, 0.7) !important;
        background-image: linear-gradient(to right, rgba(192, 192, 192, 0.1), rgba(192, 192, 192, 0.5), rgba(192, 192, 192, 0.1), rgba(192, 192, 192, 0.5)) !important;
        background-size: 300% 100% !important;
        animation: flowLeftToRight 3s linear infinite !important;
    }

    /* 🥇 Hạng Vàng (#FFD700) */
    .glow-vang {
        box-shadow: 0 0 16px rgba(255, 215, 0, 0.85) !important;
        text-shadow: 0 0 4px rgba(255, 215, 0, 0.6) !important;
        background-image: linear-gradient(to right, rgba(255, 215, 0, 0.1), rgba(255, 215, 0, 0.4), rgba(255, 215, 0, 0.1), rgba(255, 215, 0, 0.4)) !important;
        background-size: 300% 100% !important;
        animation: flowLeftToRight 3s linear infinite !important;
    }

    /* 💠 Hạng Bạch Kim (#00CFFF) */
    .glow-bachkim {
        box-shadow: 0 0 22px rgba(0, 207, 255, 0.9) !important;
        text-shadow: 0 0 6px rgba(0, 207, 255, 0.7) !important;
        background-image: linear-gradient(to right, rgba(0, 207, 255, 0.1), rgba(0, 207, 255, 0.4), rgba(0, 207, 255, 0.1), rgba(0, 207, 255, 0.4)) !important;
        background-size: 300% 100% !important;
        animation: flowLeftToRight 3s linear infinite !important;
    }

    /* 💎 Hạng Kim Cương (Tím - Xanh) */
    .glow-kimcuong {
        box-shadow: 0 0 30px rgba(138, 43, 226, 0.8), inset 0 0 15px rgba(0, 207, 255, 0.5) !important;
        color: #00CFFF !important;
        text-shadow: 0 0 8px rgba(138, 43, 226, 0.9) !important;
        border: 1px solid #9b4dff !important;
        background-image: linear-gradient(to right, rgba(138, 43, 226, 0.15), rgba(0, 207, 255, 0.4), rgba(138, 43, 226, 0.15), rgba(0, 207, 255, 0.4)) !important;
        background-size: 300% 100% !important;
        animation: flowLeftToRight 3.5s linear infinite !important;
    }
</style>

<div class="container-fluid fade-in-up mt-4">
    @Html.AntiForgeryToken()

    <div class="row mb-4 g-3 align-items-stretch">
        <div class="col-md-4">
            <div class="stat-card h-100 d-flex align-items-center">
                <div class="stat-icon" style="background: linear-gradient(135deg, #FFD700, #FF4500);">
                    <i class="bi bi-journal-bookmark-fill"></i>
                </div>
                <div class="stat-info">
                    <h6>Tổng Đơn Đặt</h6>
                    <h3 id="totalCount">@totalCards</h3>
                </div>
            </div>
        </div>

        <div class="col-md-8">
            <div class="stat-card h-100 d-flex align-items-center justify-content-between flex-wrap gap-3">
                <div>
                    <h2 class="page-title mb-1">LỊCH SỬ ĐẶT PHÒNG</h2>

                    <div class="mt-2">

                        <span class="badge rounded-pill px-2 py-1"
                              style="
                font-size: 0.75rem;
                color: #FF4500;
                border: 1px solid #FF4500;
                background-color: rgba(255, 69, 0, 0.1);">
                            <i class="bi bi-star-fill me-1"></i>
                            Điểm tích lũy: @totalPoints pt
                        </span>

                        <span class="badge rounded-pill px-2 py-1 @glowClass"
                              style="
        font-size: 0.75rem;
        color: @colorHex;
        border: 1px solid @colorHex;
        transition: all 0.3s ease;">
                            <i class="bi @iconClass me-1"></i>
                            Hạng: @tenHang
                        </span>
                    </div>

                    <p class="text-secondary mb-0 small mt-2">
                        Quản lý và theo dõi danh sách các đơn đặt phòng của bạn
                    </p>
                </div>

                <div class="d-flex align-items-center gap-4">

                    <div class="text-end d-none d-sm-block">
                        <span class="small text-muted text-uppercase fw-bold"">
                            <i class="bi bi-wallet2 me-1"></i>Đã thanh toán
                        </span>

                        <div class="fs-4 fw-bold mt-1" style="color: #20c997;">
                            @totalPaid.ToString("N0") đ
                        </div>
                    </div>

                    <a asp-controller="Home"
                       asp-action="Index"
                       class="btn btn-primary-luxury text-decoration-none text-nowrap">
                        <i class="bi bi-search-heart me-1"></i> Khám phá
                    </a>

                </div>
            </div>
        </div>
    </div>

    @if (!Model.Any())
    {
        <div class="text-center py-5 glass-container">
            <i class="bi bi-journal-x" style="font-size: 4rem; color: var(--yellow); opacity: 0.5;"></i>
            <h4 class="mt-3" style="color: var(--text-main);">Bạn chưa có đơn đặt phòng nào</h4>
            <a asp-controller="Home" asp-action="Index" class="btn btn-outline-warning mt-3 rounded-pill px-4">
                <i class="bi bi-arrow-right-circle me-1"></i> Bắt đầu đặt phòng ngay
            </a>
        </div>
    }
    else
    {
        <div class="glass-container p-4">
            <div class="toolbar-wrapper mb-4">
                <div class="search-box-luxury">
                    <i class="bi bi-search"></i>
                    <input type="text" id="searchBooking" placeholder="Tìm tên khách sạn, số phòng, trạng thái..." autocomplete="off">
                </div>
            </div>

            <table id="bookingTable" class="w-100" style="border-collapse: collapse; background: transparent;">
                <tbody class="row g-3 align-items-stretch m-0 w-100">
                    @foreach (var item in Model)
                    {
                        <tr class="col-xl-4 col-lg-6 col-md-12 d-block" style="border: none; background: transparent; padding-left: calc(var(--bs-gutter-x) * .5); padding-right: calc(var(--bs-gutter-x) * .5);">
                            <td class="d-block w-100 h-100 p-0" style="border: none;">
                                <div class="stat-card h-100 d-flex flex-column">
                                    <div class="d-flex justify-content-between align-items-center mb-3 pb-3" style="border-bottom: 1px solid rgba(255, 255, 255, 0.05);">
                                        <span class="small" style="color: var(--text-muted);">
                                            <i class="bi bi-clock-history me-1"></i> @item.NgayTao.ToString("dd/MM/yyyy HH:mm")
                                        </span>

                                        @if (item.TrangThaiDatPhong == "Chờ xác nhận")
                                        {
                                            <span class="badge text-dark fw-bold px-3 py-2 rounded-pill" style="background-color: var(--yellow);">
                                                <i class="bi bi-hourglass-split me-1"></i>@item.TrangThaiDatPhong
                                            </span>
                                        }
                                        else if (item.TrangThaiDatPhong == "Đã xác nhận")
                                        {
                                            <span class="badge fw-bold px-3 py-2 rounded-pill" style="background-color: #0dcaf0; color: #000;">
                                                <i class="bi bi-check-circle me-1"></i>@item.TrangThaiDatPhong
                                            </span>
                                        }
                                        else if (item.TrangThaiDatPhong == "Đã thanh toán" || item.TrangThaiDatPhong == "Hoàn thành")
                                        {
                                            <span class="badge fw-bold px-3 py-2 rounded-pill" style="background-color: #198754; color: #fff;">
                                                <i class="bi bi-check2-all me-1"></i>@item.TrangThaiDatPhong
                                            </span>
                                        }
                                        else if (item.TrangThaiDatPhong == "Đã hủy")
                                        {
                                            <span class="badge fw-bold px-3 py-2 rounded-pill" style="background-color: var(--orange); color: #fff;">
                                                <i class="bi bi-x-circle me-1"></i>@item.TrangThaiDatPhong
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="badge fw-bold px-3 py-2 rounded-pill" style="background-color: #6c757d; color: #fff;">
                                                <i class="bi bi-info-circle me-1"></i>@item.TrangThaiDatPhong
                                            </span>
                                        }
                                    </div>

                                    <h5 class="fw-bold mb-4 text-uppercase" style="color: var(--yellow); letter-spacing: 0.5px; font-size: 1.15rem;">
                                        <i class="bi bi-building-fill-check me-2"></i>@(item.Phong?.KhachSan?.TenKhachSan ?? "Khách sạn")
                                    </h5>

                                    <div class="row mb-3 flex-grow-1">
                                        <div class="col-5">
                                            <p class="mb-1 small" style="color: var(--text-muted);">Số phòng</p>
                                            <p class="fw-bold mb-0" style="color: var(--text-main); font-size: 1.1rem;">
                                                <i class="bi bi-door-open text-secondary me-1"></i> @item.Phong?.SoPhong
                                            </p>
                                        </div>
                                        <div class="col-7 text-end">
                                            @{
                                                int soNgayO = (item.NgayTraPhong - item.NgayNhanPhong).Days;
                                                if (soNgayO <= 0) soNgayO = 1;
                                                decimal tongTien = (item.Phong?.GiaPhong ?? 0) * soNgayO;

                                                // TÍNH TOÁN ĐIỂM CỦA HÓA ĐƠN NÀY
                                                int diemThuong = (int)(tongTien / 100000);
                                            }
                                            <p class="mb-1 small" style="color: var(--text-muted);">Tổng thanh toán</p>
                                            <p class="fw-bold mb-0 fs-5 lh-1" style="color: #20c997;">@tongTien.ToString("N0") đ</p>

                                            @if (diemThuong > 0)
                                            {
                                                if (item.TrangThaiThanhToan == "Đã thanh toán")
                                                {
                                                    <div class="mt-2">
                                                        <span class="badge border border-warning text-warning rounded-pill px-2 py-1" style="font-size: 0.75rem; background-color: rgba(255, 193, 7, 0.1);" title="Điểm nhận được sau khi thanh toán">
                                                            <i class="bi bi-star me-1"></i>Dự kiến +@diemThuong điểm
                                                        </span>
                                                    </div>
                                                }
                                                else if (item.TrangThaiDatPhong != "Đã hủy")
                                                {
                                                    <div class="mt-2">
                                                        <span class="badge border border-warning text-warning rounded-pill px-2 py-1" style="font-size: 0.75rem; background-color: rgba(255, 193, 7, 0.1);" title="Điểm nhận được sau khi thanh toán">
                                                            <i class="bi bi-star me-1"></i>Dự kiến +@diemThuong điểm
                                                        </span>
                                                    </div>
                                                }
                                            }
                                        </div>
                                    </div>

                                    <div class="d-flex align-items-center justify-content-between p-3 rounded-3 mb-4 mt-auto" style="background: rgba(0, 0, 0, 0.4); border: 1px solid rgba(255, 255, 255, 0.05);">
                                        <div class="text-center">
                                            <span class="d-block small" style="color: var(--text-muted);">Nhận phòng</span>
                                            <span class="fw-bold" style="color: var(--text-main);">@item.NgayNhanPhong.ToString("dd/MM/yyyy")</span>
                                        </div>
                                        <i class="bi bi-arrow-right" style="color: var(--yellow); opacity: 0.7;"></i>
                                        <div class="text-center">
                                            <span class="d-block small" style="color: var(--text-muted);">Trả phòng</span>
                                            <span class="fw-bold" style="color: var(--text-main);">@item.NgayTraPhong.ToString("dd/MM/yyyy")</span>
                                        </div>
                                    </div>

                                    <div class="d-flex justify-content-end gap-2 border-top pt-3" style="border-color: rgba(255,255,255,0.05) !important;">
                                        @if (item.TrangThaiDatPhong == "Chờ xác nhận")
                                        {
                                            <form asp-action="HuyDatPhong" asp-controller="DatPhongs" method="post" class="d-inline huyForm">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="id" value="@item.ID" />
                                                <button type="button" class="btn btn-icon-luxury btn-danger-glow btnHuyDon" title="Hủy đơn">
                                                    <i class="bi bi-x-lg"></i>
                                                </button>
                                            </form>
                                        }
                                        else if ((item.TrangThaiDatPhong == "Đã xác nhận" || item.TrangThaiDatPhong == "Đang lưu trú") && item.TrangThaiThanhToan != "Đã thanh toán")
                                        {
                                            <button type="button" class="btn btn-icon-luxury btn-success-glow" title="Thanh toán QR" data-bs-toggle="modal" data-bs-target="#dynamicAjaxModal" data-title="Thanh toán đơn #@item.ID" data-url="@Url.Action("ThanhToanQRPartial", "DatPhongs", new { id = item.ID })">
                                                <i class="bi bi-qr-code-scan"></i>
                                            </button>
                                        }
                                        else if (item.TrangThaiDatPhong == "Đã hủy")
                                        {
                                            <button type="button" class="btn btn-icon-luxury btn-danger-glow" onclick="confirmDelete('@item.ID')" title="Xóa lịch sử này">
                                                <i class="bi bi-trash-fill"></i>
                                            </button>
                                            <form id="deleteForm-@item.ID" method="post" asp-action="Delete" asp-controller="DatPhongs" asp-route-id="@item.ID" style="display:none;">
                                                @Html.AntiForgeryToken()
                                            </form>
                                        }

                                        <button type="button" class="btn btn-icon-luxury btn-info-glow" title="Chi tiết đơn" data-bs-toggle="modal" data-bs-target="#dynamicAjaxModal" data-title="Chi tiết mã đơn #@item.ID" data-url="@Url.Action("DetailsPartial", "DatPhongs", new { id = item.ID })">
                                            <i class="bi bi-info-circle"></i>
                                        </button>
                                    </div>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>

            <div id="noResults" class="text-center py-5" style="display: none;">
                <div class="mb-3">
                    <i class="bi bi-search" style="font-size: 3rem; color: var(--yellow); opacity: 0.5;"></i>
                </div>
                <h5 class="text-light">Không tìm thấy đơn đặt phòng nào</h5>
                <button type="button" onclick="pageConfig.clearSearch()" class="btn btn-outline-warning mt-2 rounded-pill px-4">
                    <i class="bi bi-arrow-clockwise me-1"></i> Hiển thị tất cả
                </button>
            </div>

            <div class="table-footer d-flex justify-content-between align-items-center mt-3 pt-3" style="border-top: 1px solid var(--border-color)">
                <span class="text-secondary small">Đang hiển thị <strong id="visibleCount" class="text-light">0</strong> đơn</span>
                <ul id="pagination" class="pagination-luxury m-0"></ul>
            </div>
        </div>
    }
</div>

<div class="modal fade" id="dynamicAjaxModal" tabindex="-1" aria-labelledby="dynamicAjaxModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered modal-dialog-scrollable">
        <div class="modal-content custom-modal-bg text-light" style="border: 1px solid rgba(255, 215, 0, 0.2); border-radius: 15px;">
            <div class="modal-header border-bottom-0 pb-0">
                <h5 class="modal-title text-warning fw-bold" id="dynamicAjaxModalLabel">
                    <div class="spinner-border spinner-border-sm text-warning me-2" role="status"></div> Đang tải...
                </h5>
                <button type="button" class="btn-close btn-close-white opacity-75" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body pt-3 pb-4"></div>
        </div>
    </div>
</div>

@section Scripts {
    <input type="hidden" id="successMessage" value="@TempData["SuccessMessage"]" />
    <input type="hidden" id="errorMessage" value="@TempData["ErrorMessage"]" />
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="~/js/Share/Success.js" asp-append-version="true"></script>
    <script src="~/js/Share/PhanTrang.js" asp-append-version="true"></script>
    <script src="~/js/Share/Delete.js" asp-append-version="true"></script>
    <script src="~/js/Share/DoiTien.js" asp-append-version="true"></script>
    <script src="~/js/Share/PopUpDetails.js" asp-append-version="true"></script>

    <script>
        let checkPaymentInterval;
        document.getElementById('dynamicAjaxModal').addEventListener('shown.bs.modal', function (event) {
            let button = event.relatedTarget;
            if (!button) return;
            let url = button.getAttribute('data-url');
            if (url && url.includes('ThanhToanQRPartial')) {
                let donHangId = url.split('/').pop();
                if (checkPaymentInterval) clearInterval(checkPaymentInterval);
                checkPaymentInterval = setInterval(function () {
                    let checkUrl = `/DatPhongs/KiemTraTrangThai?id=${donHangId}&t=${new Date().getTime()}`;
                    fetch(checkUrl, { cache: 'no-store' })
                        .then(res => res.json())
                        .then(data => {
                            let isPaid = data.daThanhToan || data.DaThanhToan;
                            if (isPaid === true || String(isPaid).toLowerCase() === 'true') {
                                clearInterval(checkPaymentInterval);
                                const statusContainer = document.getElementById('paymentStatusContainer');
                                if (statusContainer) {
                                    statusContainer.innerHTML = `
                                        <div class="p-3 rounded-pill d-flex justify-content-center align-items-center" style="background: rgba(40, 167, 69, 0.15); border: 1px solid rgba(40, 167, 69, 0.4);">
                                            <i class="bi bi-check-circle-fill text-success me-2 fs-5"></i>
                                            <span class="text-success fw-bold">Đã thanh toán thành công!</span>
                                        </div>`;
                                }
                                setTimeout(() => {
                                    const modalEl = document.getElementById('dynamicAjaxModal');
                                    const modalInstance = bootstrap.Modal.getInstance(modalEl);
                                    if (modalInstance) modalInstance.hide();
                                    location.reload();
                                }, 2000);
                            }
                        })
                        .catch(err => console.error("Lỗi quét QR:", err));
                }, 2000);
            }
        });
        document.getElementById('dynamicAjaxModal').addEventListener('hidden.bs.modal', function () {
            if (checkPaymentInterval) clearInterval(checkPaymentInterval);
        });
    </script>
    <script>
        var pageConfig;
        document.addEventListener("DOMContentLoaded", function () {
            if (document.getElementById('bookingTable')) {
                pageConfig = new TablePaginator({
                    tableId: 'bookingTable',
                    paginationId: 'pagination',
                    visibleCountId: 'visibleCount',
                    noResultsId: 'noResults',
                    rowsPerPage: 9
                });
            }
            const searchInput = document.getElementById('searchBooking');
            const rows = document.querySelectorAll('#bookingTable tbody tr');
            const visibleCountEl = document.getElementById('visibleCount');
            const noResultsEl = document.getElementById('noResults');
            const paginationEl = document.getElementById('pagination');
            function removeAccents(str) {
                return str.normalize('NFD').replace(/[\u0300-\u036f]/g, '').replace(/đ/g, 'd').replace(/Đ/g, 'D');
            }
            if (searchInput) {
                searchInput.addEventListener('input', function () {
                    let keyword = removeAccents(this.value.toLowerCase().trim());
                    let count = 0;
                    rows.forEach(row => {
                        let textContent = removeAccents(row.innerText.toLowerCase());
                        if (textContent.includes(keyword)) {
                            row.classList.remove('d-none');
                            row.classList.add('d-block');
                            count++;
                        } else {
                            row.classList.remove('d-block');
                            row.classList.add('d-none');
                        }
                    });
                    if (visibleCountEl) visibleCountEl.innerText = count;
                    if (count === 0) {
                        noResultsEl.style.display = 'block';
                        if (paginationEl) paginationEl.style.display = 'none';
                    } else {
                        noResultsEl.style.display = 'none';
                        if (paginationEl) paginationEl.style.display = (keyword === '') ? 'flex' : 'none';
                    }
                    if (keyword === '' && typeof pageConfig !== 'undefined' && typeof pageConfig.clearSearch === 'function') {
                        pageConfig.clearSearch();
                    }
                });
            }
            document.querySelectorAll(".btnHuyDon").forEach(button => {
                button.addEventListener("click", function () {
                    const form = this.closest("form");
                    Swal.fire({
                        title: 'Bạn muốn hủy đặt phòng?',
                        text: "Thao tác này không thể hoàn tác!",
                        icon: 'warning',
                        showCancelButton: true,
                        confirmButtonColor: '#dc3545',
                        cancelButtonColor: '#6c757d',
                        confirmButtonText: 'Đồng ý hủy',
                        cancelButtonText: 'Quay lại',
                        background: '#1e1e24',
                        color: '#ffffff',
                        customClass: { popup: 'custom-modal-bg' }
                    }).then((result) => {
                        if (result.isConfirmed) {
                            Swal.fire({
                                title: 'Đang xử lý...',
                                background: '#1e1e24',
                                color: '#ffffff',
                                didOpen: () => Swal.showLoading()
                            });
                            form.submit();
                        }
                    });
                });
            });
        });
    </script>
}