@model IEnumerable<DoAn_HotelBooking.Models.DatPhong>

@{
    ViewData["Title"] = "Danh sách hóa đơn";
    var quyenHan = Context.Session.GetString("QuyenHan");
}

<link rel="stylesheet" href="~/css/KhachSan/Index.css" asp-append-version="true" />
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">

<div class="container-fluid fade-in-up mt-4">
    @Html.AntiForgeryToken()

    <div class="row mb-4 g-3 align-items-stretch">
        <div class="col-md-4">
            <div class="stat-card h-100 d-flex align-items-center">
                <div class="stat-icon" style="background: linear-gradient(135deg, #198754, #20c997);">
                    <i class="bi bi-receipt-cutoff"></i>
                </div>
                <div class="stat-info">
                    <h6>Tổng Số Hóa Đơn</h6>
                    <h3 id="totalCount">@Model.Count()</h3>
                </div>
            </div>
        </div>

        <div class="col-md-8">
            <div class="stat-card h-100 d-flex align-items-center justify-content-between">
                <div>
                    <h2 class="page-title mb-1">@ViewData["Title"]?.ToString().ToUpper()</h2>
                    <p class="text-secondary mb-0 small">
                        <i class="bi bi-building text-warning me-1"></i> Khách sạn: <strong>@ViewBag.KhachSan</strong>
                    </p>
                </div>
                <div class="d-flex align-items-center gap-4">
                    <div class="text-end">
                        <span class="text-secondary small d-block mb-1">Tổng doanh thu</span>
                        <strong class="text-success fs-4" id="tongCongTop">0 VNĐ</strong>
                    </div>
                    <div style="width: 1px; height: 40px; background: rgba(255,255,255,0.1);"></div>
                    <a href="javascript:location.reload();" class="btn btn-primary-luxury text-decoration-none">
                        <i class="bi bi-arrow-clockwise me-1"></i> Tải lại
                    </a>
                </div>
            </div>
        </div>
    </div>

    <div class="glass-container">
        <div class="toolbar-wrapper mb-3">
            <div class="search-box-luxury">
                <i class="bi bi-search"></i>
                <input type="text" id="searchHoaDon" placeholder="Tìm kiếm khách hàng, phòng, tổng tiền..." autocomplete="off">
            </div>
        </div>

        <div class="table-responsive">
            <table class="table custom-table align-middle" id="hoaDonTable">
                <thead>
                    <tr>
                        <th class="text-center" style="width: 5%">#</th>
                        <th class="text-center">Ngày tạo</th>
                        <th class="text-center">Khách hàng & Phòng</th>
                        <th class="text-center">Nhận - Trả</th>
                        <th class="text-center">Tổng tiền</th>
                        <th class="text-center">Trạng thái</th>
                        <th class="text-center">Tác vụ</th>
                    </tr>
                </thead>
                <tbody>
                    @{
                        int stt = 1;
                    }
                    @foreach (var item in Model)
                    {
                        int soNgayO = (item.NgayTraPhong - item.NgayNhanPhong).Days;
                        if (soNgayO <= 0) soNgayO = 1;
                        decimal tongTien = (item.Phong?.GiaPhong ?? 0) * soNgayO;

                        <tr data-tongtien="@tongTien">
                            <td class="text-center text-muted fw-bold">@(stt++)</td>

                            <td class="text-center text-muted small">
                                <i class="bi bi-clock me-1"></i> @item.NgayTao.ToString("dd/MM/yyyy")
                            </td>

                            <td class="text-center">
                                <div class="fw-bold" style="color: var(--yellow); font-size: 1.05rem;">
                                    <i class="bi bi-person-fill me-2"></i>@item.TaiKhoan?.HoVaTen
                                </div>
                                <div class="text-muted small mt-1">
                                    <i class="bi bi-door-closed me-1"></i>Phòng: <span class="text-light">@item.Phong?.SoPhong</span>
                                </div>
                            </td>

                            <td class="text-center fw-semibold text-light small">
                                <span class="fw-bold text-success">@item.NgayNhanPhong.ToString("dd/MM")</span>
                                <i class="bi bi-arrow-right mx-1 text-muted"></i>
                                <span class="fw-bold text-danger">@item.NgayTraPhong.ToString("dd/MM")</span>
                            </td>

                            <td class="text-center fw-bold text-success">
                                @tongTien.ToString("N0") VNĐ
                            </td>

                            <td class="text-center">
                                <span class="badge bg-success rounded-pill px-3 py-2">
                                    <i class="bi bi-check-circle-fill me-1"></i> Đã thanh toán
                                </span>
                            </td>

                            <td class="text-center">
                                <div class="d-flex justify-content-center gap-2">
                                    @if (quyenHan == "Quản lý" || quyenHan == "Nhân viên")
                                    {
                                        <a asp-action="XuatHoaDonPDF" asp-controller="DatPhongs" asp-route-id="@item.ID" class="btn btn-icon-luxury btn-danger-glow" title="Xuất PDF Hóa Đơn">
                                            <i class="bi bi-file-earmark-pdf"></i>
                                        </a>
                                    }

                                    <button type="button" class="btn btn-icon-luxury btn-info-glow"
                                            title="Chi tiết hóa đơn"
                                            data-bs-toggle="modal"
                                            data-bs-target="#dynamicAjaxModal"
                                            data-title="Chi tiết hóa đơn #@item.ID"
                                            data-url="@Url.Action("DetailsPartial", "DatPhongs", new { id = item.ID })">
                                        <i class="bi bi-info-circle"></i>
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>

            <div id="noResults" class="text-center py-5" style="display: none;">
                <div class="mb-3">
                    <i class="bi bi-search" style="font-size: 3rem; color: var(--yellow); opacity: 0.5;"></i>
                </div>
                <h5 class="text-light">Không tìm thấy hóa đơn nào</h5>
                <p class="text-secondary">Vui lòng thử lại với từ khóa khác.</p>
                <button type="button" onclick="pageConfig.clearSearch()" class="btn btn-outline-warning mt-2 rounded-pill px-4">
                    <i class="bi bi-arrow-clockwise me-1"></i> Hiển thị tất cả
                </button>
            </div>
        </div>

        <div class="table-footer d-flex justify-content-between align-items-center mt-auto pt-3" style="border-top: 1px solid var(--border-color)">
            <span class="text-secondary small">Đang hiển thị <strong id="visibleCount" class="text-light">0</strong> đơn</span>
            <ul id="pagination" class="pagination-luxury">
            </ul>
        </div>
    </div>
</div>

<div class="modal fade" id="dynamicAjaxModal" tabindex="-1" aria-labelledby="dynamicAjaxModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered modal-dialog-scrollable">
        <div class="modal-content custom-modal-bg text-light" style="border: 1px solid rgba(255, 215, 0, 0.2); border-radius: 15px;">
            <div class="modal-header border-bottom-0 pb-0">
                <h5 class="modal-title text-warning fw-bold" id="dynamicAjaxModalLabel">
                    <div class="spinner-border spinner-border-sm text-warning me-2" role="status"></div> Đang tải...
                </h5>
                <button type="button" class="btn-close btn-close-white opacity-75" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body pt-3 pb-4">
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <input type="hidden" id="successMessage" value="@TempData["SuccessMessage"]" />
    <input type="hidden" id="errorMessage" value="@TempData["ErrorMessage"]" />

    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="~/js/Share/Delete.js" asp-append-version="true"></script>
    <script src="~/js/Share/Success.js" asp-append-version="true"></script>
    <script src="~/js/share/scrolltop.js" asp-append-version="true"></script>
    <script src="~/js/Share/PhanTrang.js" asp-append-version="true"></script>
    <script src="~/js/Share/DoiTien.js" asp-append-version="true"></script>
    <script src="~/js/share/popupdetails.js" asp-append-version="true"></script>

    <script>
        var pageConfig;

        document.addEventListener("DOMContentLoaded", function () {
            // Khởi tạo giống y hệt code mẫu
            pageConfig = new TablePaginator({
                tableId: 'hoaDonTable',
                searchInputId: 'searchHoaDon',
                paginationId: 'pagination',
                visibleCountId: 'visibleCount',
                noResultsId: 'noResults',
                rowsPerPage: 20
            });

            // Gọi hàm tính tiền ngay khi load trang
            updateTongDoanhThu();

            // Cập nhật lại tiền mỗi khi gõ tìm kiếm
            document.getElementById('searchHoaDon').addEventListener('input', updateTongDoanhThu);

            // Ghi đè thêm xíu logic vào hàm clearSearch() của thư viện
            // Để khi ấn nút "Hiển thị tất cả", nó không chỉ xoá chữ mà còn tính lại doanh thu tổng
            const originalClear = pageConfig.clearSearch.bind(pageConfig);
            pageConfig.clearSearch = function() {
                originalClear(); // Chạy lệnh xóa của thư viện
                updateTongDoanhThu(); // Tính lại tiền
            };
        });

        // Hàm tính toán chuyên nghiệp, không bị ảnh hưởng bởi phân trang
        function updateTongDoanhThu() {
            const filter = document.getElementById("searchHoaDon").value.toLowerCase().trim();
            const rows = document.querySelectorAll("#hoaDonTable tbody tr");
            let total = 0;

            rows.forEach(row => {
                if (row.innerText.toLowerCase().includes(filter)) {
                    total += parseFloat(row.getAttribute("data-tongtien")) || 0;
                }
            });

            document.getElementById("tongCongTop").textContent = total.toLocaleString('vi-VN') + ' VNĐ';
        }
    </script>
}