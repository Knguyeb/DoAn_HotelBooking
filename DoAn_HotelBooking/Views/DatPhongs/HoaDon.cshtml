@model IEnumerable<dynamic>

@{
    ViewData["Title"] = "Tổng doanh thu";
    var quyenHan = Context.Session.GetString("QuyenHan");
}

<link rel="stylesheet" href="~/css/KhachSan/Index.css" asp-append-version="true" />
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">

<div class="container-fluid fade-in-up mt-4">
    @Html.AntiForgeryToken()

    <div class="row mb-4 g-3 align-items-stretch">
        <div class="col-md-4">
            <div class="stat-card h-100 d-flex align-items-center">
                <div class="stat-icon" style="background: linear-gradient(135deg, #198754, #20c997);">
                    <i class="bi bi-people-fill"></i>
                </div>
                <div class="stat-info">
                    <h6>Số Khách Đã Giao Dịch</h6>
                    <h3 id="totalCount">@Model.Count()</h3>
                </div>
            </div>
        </div>

        <div class="col-md-8">
            <div class="stat-card h-100 d-flex align-items-center justify-content-between">
                <div>
                    <h2 class="page-title mb-1">@ViewData["Title"]?.ToString().ToUpper()</h2>
                    <p class="text-secondary mb-0 small">
                        <i class="bi bi-building text-warning me-1"></i> Cơ sở: <strong>@ViewBag.KhachSan</strong>
                    </p>
                </div>
                <div class="d-flex align-items-center gap-4">
                    <div class="text-end">
                        <span class="text-secondary small d-block mb-1">Tổng doanh thu cơ sở</span>
                        <strong class="text-success fs-4" id="tongCongTop" data-base-price="0">0 đ</strong>
                    </div>
                    <div style="width: 1px; height: 40px; background: rgba(255,255,255,0.1);"></div>
                    <a href="javascript:location.reload();" class="btn btn-primary-luxury text-decoration-none">
                        <i class="bi bi-arrow-clockwise me-1"></i> Tải lại
                    </a>
                </div>
            </div>
        </div>
    </div>

    <div class="glass-container">
        <div class="toolbar-wrapper mb-3">
            <div class="search-box-luxury">
                <i class="bi bi-search"></i>
                <input type="text" id="searchKhachHang" placeholder="Tìm kiếm tên khách hàng, số điện thoại..." autocomplete="off">
            </div>
        </div>

        <div class="table-responsive">
            <table class="table custom-table align-middle" id="khachHangTable">
                <thead>
                    <tr>
                        <th class="text-center" style="width: 5%">#</th>
                        <th class="text-center" style="width: 35%">Khách hàng</th>
                        <th class="text-center" style="width: 20%">Số lượng hóa đơn</th>
                        <th class="text-center" style="width: 25%">Tổng tiền tích lũy</th>
                        <th class="text-center" style="width: 15%">Tác vụ</th>
                    </tr>
                </thead>
                <tbody>
                    @{
                        int stt = 1;
                    }
                    @foreach (var item in Model)
                    {
                        <tr data-tongtien="@item.TongTienTichLuy">
                            <td class="text-center text-muted fw-bold">@(stt++)</td>

                            <td class="text-center">
                                <div class="fw-bold" style="color: var(--yellow); font-size: 1.05rem;">
                                    <i class="bi bi-person-fill me-2"></i>@item.TenKhachHang
                                </div>
                                <div class="text-secondary small mt-1">
                                    <i class="bi bi-telephone me-1"></i>SĐT: <span class="text-light me-3">@item.SoDienThoai</span>
                                    <i class="bi bi-envelope me-1"></i>Email: <span class="text-light">@item.Email</span>
                                </div>
                            </td>

                            <td class="text-center">
                                <span class="badge bg-dark border border-warning text-warning rounded-pill px-3 py-1 fw-bold">
                                    @item.SoLuongHoaDon Đơn hoàn thành
                                </span>
                            </td>

                            <td class="text-center fw-bold text-success fs-5" data-base-price="@item.TongTienTichLuy">
                                @item.TongTienTichLuy.ToString("N0") đ
                            </td>

                            <td class="text-center">
                                <a asp-action="ChiTietHoaDonKhach" asp-controller="DatPhongs" asp-route-id="@item.TaiKhoanId"
                                   class="btn btn-icon-luxury btn-info-glow" title="Xem chi tiết các hóa đơn">
                                    <i class="bi bi-info-circle"></i>
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>

            <div id="noResults" class="text-center py-5" style="display: none;">
                <div class="mb-3">
                    <i class="bi bi-search" style="font-size: 3rem; color: var(--yellow); opacity: 0.5;"></i>
                </div>
                <h5 class="text-light">Không tìm thấy khách hàng nào</h5>
                <p class="text-secondary">Vui lòng thử lại với từ khóa khác.</p>
                <button type="button" onclick="pageConfig.clearSearch()" class="btn btn-outline-warning mt-2 rounded-pill px-4">
                    <i class="bi bi-arrow-clockwise me-1"></i> Hiển thị tất cả
                </button>
            </div>
        </div>

        <div class="table-footer d-flex justify-content-between align-items-center mt-auto pt-3" style="border-top: 1px solid var(--border-color)">
            <span class="text-secondary small">Đang hiển thị <strong id="visibleCount" class="text-light">0</strong> khách hàng</span>
            <ul id="pagination" class="pagination-luxury">
            </ul>
        </div>
    </div>
</div>

<div class="modal fade" id="dynamicAjaxModal" tabindex="-1" aria-labelledby="dynamicAjaxModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-centered modal-dialog-scrollable">
        <div class="modal-content custom-modal-bg text-light" style="border: 1px solid rgba(255, 215, 0, 0.2); border-radius: 15px;">
            <div class="modal-header border-bottom-0 pb-0">
                <h5 class="modal-title text-warning fw-bold" id="dynamicAjaxModalLabel">
                    <div class="spinner-border spinner-border-sm text-warning me-2" role="status"></div> Đang tải...
                </h5>
                <button type="button" class="btn-close btn-close-white opacity-75" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body pt-3 pb-4">
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <input type="hidden" id="successMessage" value="@TempData["SuccessMessage"]" />
    <input type="hidden" id="errorMessage" value="@TempData["ErrorMessage"]" />

    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="~/js/Share/Delete.js" asp-append-version="true"></script>
    <script src="~/js/Share/Success.js" asp-append-version="true"></script>
    <script src="~/js/Share/ScrollTop.js" asp-append-version="true"></script>
    <script src="~/js/Share/PhanTrang.js" asp-append-version="true"></script>
    <script src="~/js/Share/DoiTien.js" asp-append-version="true"></script>
    <script src="~/js/Share/PopUpDetails.js" asp-append-version="true"></script>

    <script>
        var pageConfig;

        document.addEventListener("DOMContentLoaded", function () {
            pageConfig = new TablePaginator({
                tableId: 'khachHangTable',
                searchInputId: 'searchKhachHang',
                paginationId: 'pagination',
                visibleCountId: 'visibleCount',
                noResultsId: 'noResults',
                rowsPerPage: 20
            });

            // Gọi hàm tính tiền ngay khi load trang
            updateTongDoanhThu();

            // Cập nhật lại tiền mỗi khi gõ tìm kiếm
            document.getElementById('searchKhachHang').addEventListener('input', updateTongDoanhThu);

            // Ghi đè thêm logic vào hàm clearSearch()
            const originalClear = pageConfig.clearSearch.bind(pageConfig);
            pageConfig.clearSearch = function() {
                originalClear();
                updateTongDoanhThu();
            };
        });

        // ✅ ĐÃ SỬA: Hàm tính toán hỗ trợ thư viện DoiTien.js
        function updateTongDoanhThu() {
            const filter = document.getElementById("searchKhachHang").value.toLowerCase().trim();
            const rows = document.querySelectorAll("#khachHangTable tbody tr");
            let total = 0;

            rows.forEach(row => {
                if (row.innerText.toLowerCase().includes(filter)) {
                    total += parseFloat(row.getAttribute("data-tongtien")) || 0;
                }
            });

            const tongCongEl = document.getElementById("tongCongTop");
            tongCongEl.setAttribute("data-base-price", total); // Gắn base-price để JS nhận dạng

            // Nếu đang chọn hệ tiền tệ khác VNĐ thì lấy tỉ giá nhân lên
            if (window.formatCurrency && window.currentRates && window.currentSelectedCurrency) {
                let rate = window.currentRates[window.currentSelectedCurrency] || 1;
                let convertedPrice = total * rate;
                tongCongEl.innerHTML = window.formatCurrency(convertedPrice, window.currentSelectedCurrency);
            } else {
                tongCongEl.innerHTML = total.toLocaleString('vi-VN') + ' đ';
            }
        }
    </script>
}