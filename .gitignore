# ReSharper / JetBrains add-ins
_ReSharper*/
*.[Rr]e[Ss]harper
*.DotSettings.user

# Web workbench (sass)
.sass-cache/

# Publish Web Output
publish/
*.[Pp]ublish.xml
*.azurePubxml
*.pubxml
*.publishproj
PublishScripts/

# NuGet Packages
*.nupkg
*.snupkg
**/[Pp]ackages/*
!**/[Pp]ackages/build/
*.nuget.props
*.nuget.targets

# Microsoft Azure
csx/
*.build.csdef
ecf/
rcf/

# Visual Studio cache files
*.[Cc]ache
!?*.[Cc]ache/

# Others
ClientBin/
~$*
*~
*.dbmdl
*.dbproj.schemaview
*.jfm
*.pfx
*.publishsettings

# SQL Server files
*.mdf
*.ldf
*.ndf

# Node.js
node_modules/
.ntvs_analysis.dat

# Python Tools for Visual Studio (PTVS)
__pycache__/
*.pyc

# MSBuild Binary and Structured Log
*.binlog

# Local History for Visual Studio
.localhistory/

